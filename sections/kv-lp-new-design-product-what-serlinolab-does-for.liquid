{{ 'kv-lp-new-design-product-what-serlinolab-does-for.css' | asset_url | stylesheet_tag }}

<section class="lp-what-serlinolab" id="lp-section-{{ section.id }}" style="--mobile-height: {{ section.settings.mobile_height }}px;">
  {%- if section.settings.image_desktop != blank -%}
    <picture class="lp-what-serlinolab__bg">
      {%- if section.settings.image_mobile != blank -%}
        <source media="(max-width: 767px)" srcset="{{ section.settings.image_mobile | image_url: width: 800 }}">
      {%- endif -%}
      <img src="{{ section.settings.image_desktop | image_url: width: 2000 }}" alt="{{ section.settings.heading | escape }}" loading="lazy" width="{{ section.settings.image_desktop.width }}" height="{{ section.settings.image_desktop.height }}">
    </picture>
  {%- endif -%}

  <div class="lp-what-serlinolab__overlay"></div>

  <div class="lp-what-serlinolab__container" id="lp-what-serlinolab-container">
    <div class="lp-what-serlinolab__content">
      <h2 class="lp-what-serlinolab__heading">{{ section.settings.heading | newline_to_br }}</h2>
      
      <div class="lp-what-serlinolab__benefits-grid">
        {%- for block in section.blocks -%}
          <div class="lp-benefit-item" {{ block.shopify_attributes }}>
            <div class="lp-benefit-item__icon">
              {%- if block.settings.icon_svg != blank -%}
                {{ block.settings.icon_svg }}
              {%- else -%}
                <div class="lp-benefit-item__icon-placeholder"></div>
              {%- endif -%}
            </div>
            <p class="lp-benefit-item__title">{{ block.settings.title | escape }}</p>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>

  <div class="lp-trustpilot-bar">
    <div class="lp-trustpilot-bar__inner">
      <div class="lp-trustpilot-logo">
       <svg xmlns="http://www.w3.org/2000/svg" width="92" height="18" viewBox="0 0 92 18" fill="none">
  <g clip-path="url(#clip0_26730_714)">
