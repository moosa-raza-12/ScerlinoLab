    "gp_section_600496129469055852": {
      "settings": {
        "checksum": "9d9733ab36517957c6fd711013214437ddcb61fc25ffb334034fc2a195219788_1_1_1_0__1",
        "ggWogvCe41J_text": "<p>★ ★ ★ ★ ★ Over 72,000+ Happy Customers | Made in Italy 🇮🇹 |</p>",
        "ggndTQ8NpAp_text": "<p>★ ★ ★ ★ ★ Over 72,000+ Happy Customers | Made in Italy 🇮🇹 | Approved by Italian Pharmacists</p>",
        "section_preload": "true"
