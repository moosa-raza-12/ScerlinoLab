{{ 'kv-lp-new-design-product-note-from-our-italian.css' | asset_url | stylesheet_tag }}

<section class="lp-note-lab" id="lp-note-lab-{{ section.id }}">
  <div class="lp-note-lab__container" id="lp-note-lab-container">
    <div class="lp-note-lab__text-content">
      {% if section.settings.badge_text != blank %}
        <div class="lp-note-lab__badge">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
            <g clip-path="url(#clip0_26975_180)">
              <path d="M15.013 4.3876C13.9049 2.06448 11.6212 0.596351 9.05054 0.562601C6.47429 0.528851 4.19054 1.94635 3.04304 4.2751C1.85054 6.68823 2.13179 9.48385 3.78554 11.582L8.05492 17.0045C8.27429 17.2801 8.60054 17.4376 8.94929 17.4376C9.29804 17.4376 9.62429 17.2801 9.84367 17.0045L14.2255 11.4357C15.8174 9.41073 16.1155 6.71635 15.013 4.39323V4.3876ZM13.348 10.7382L8.94367 16.307L4.67429 10.8845C3.29617 9.1351 3.05992 6.78948 4.05554 4.77573C5.01179 2.84073 6.83992 1.69323 8.95492 1.69323H9.03929C11.2105 1.72698 13.0668 2.91385 14.0005 4.87698C14.9343 6.8401 14.6924 9.02823 13.348 10.7382Z" fill="black"/>
              <path d="M8.94942 4.02734C7.2563 4.02734 5.87817 5.40547 5.87817 7.09859C5.87817 8.79172 7.2563 10.1698 8.94942 10.1698C10.6425 10.1698 12.0207 8.79172 12.0207 7.09859C12.0207 5.40547 10.6425 4.02734 8.94942 4.02734ZM8.94942 9.03922C7.87505 9.03922 7.00317 8.16734 7.00317 7.09297C7.00317 6.01859 7.87505 5.14672 8.94942 5.14672C10.0238 5.14672 10.8957 6.01859 10.8957 7.09297C10.8957 8.16734 10.0238 9.03922 8.94942 9.03922Z" fill="black"/>
            </g>
            <defs>
              <clipPath id="clip0_26975_180">
                <rect width="18" height="18" fill="white"/>
              </clipPath>
            </defs>
          </svg>
          <span>{{ section.settings.badge_text }}</span>
        </div>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="lp-note-lab__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      
      {% if section.settings.content != blank %}
        <div class="lp-note-lab__description">
          {{ section.settings.content }}
        </div>
      {% endif %}
    </div>

    <div class="lp-note-lab__image-wrapper">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1000 | image_tag: 
          class: 'lp-note-lab__image', 
          loading: 'lazy',
          alt: section.settings.image.alt | default: section.settings.heading
        }}
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'lp-note-lab__image placeholder-svg' }}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Note from our Italian lab",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Nocera Inferiore, Italy"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Note from our Italian lab"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>SerlinoLab is produced in a family-owned Italian lab, based in the Italian countryside, where every batch is made with hands-on care and strict quality control.</p><p>This isn’t mass production. It’s an authentic, controlled process designed for one thing: consistent results you can trust, batch after batch. That’s our core US selling point—Italian-made quality, done properly.</p><p>— SerlinoLab<br>Family-made in Italy</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Image Corner Radius",
      "default": 30
    }
  ],
  "presets": [
    {
      "name": "Note from our Italian lab",
      "settings": {
        "badge_text": "Nocera Inferiore, Italy",
        "heading": "Note from our \nItalian lab",
        "content": "<p>SerlinoLab is produced in a family-owned Italian lab, based in the Italian countryside, where every batch is made with hands-on care and strict quality control.</p><p>This isn’t mass production. It’s an authentic, controlled process designed for one thing: consistent results you can trust, batch after batch. That’s our core US selling point—Italian-made quality, done properly.</p><p>— SerlinoLab<br>Family-made in Italy</p>",
        "image_border_radius": 30
      }
    }
  ]
}
{% endschema %}