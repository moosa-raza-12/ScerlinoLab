    "gp_global_section_578003548697002949-7": {
      "type": "gp-global-section-578003548697002949",
      "settings": {
        "section_preload": "false",
        "checksum": "",
        "ggnGs12-Z1B_text": "Anti-aging ingredients <span style=\"color:#0155B6;\">clinically tested</span>",
        "ggB9ocecH-q_text": "<p>They don't just hydrate, but actively fight the signs of time</p>",
        "ggRyjsa0tmT_label": "<p>Stretches</p>",
        "gg0LM__B8FF_text": "<p>Retinol (Vitamin A)</p>",
        "gga63BqK69q_text": "<p>Actively stimulates collagen production, visibly reducing wrinkles and fine lines.</p>",
        "ggUArggES35_label": "<p>Protects</p>",
        "ggxUgzRm_Jj_text": "<p>Olive Oil</p>",
        "ggfZyen1cpu_text": "<p>Powerful antioxidant that prevents collagen loss and protects skin from environmental damage.</p>",
        "ggpuoFL-R1O_label": "<p>Plump</p>",
        "gghliwIxolK_text": "<p>Hyaluronic acid</p>",
        "ggBtHP5oI8R_text": "<p>Intensely hydrates and \"fills\" wrinkles from within for an immediate lifting effect.</p>",
        "ggSZDcGHmcC_childItem_0": "<p>Full Ingredient List</p>",
        "ggRnfRQhKZp_text": "<p><span style=\"background-color:transparent;color:#000000;font-size:11pt;\">aqua, propylene glycol, glycerin, caprylic/capric triglyceride, hydrogenated ethylhexyl olivate, glyceryl stearate se, aloe barbadensis leaf juice, sodium polyacrylate, phenoxyethanol, hydrogenated olive oil unsaponifiables, tocopherol, tetrasodium glutamate diacetate, urea, trehalose, ethylhexylglycerin, hydrolyzed rice protein, lavandula angustifolia oil, propanediol, sorbitol, linalool, lecithin, olive oil peg-8 esters, helianthus annuus seed oil, tocopheryl acetate, hydroxyethylcellulose, sodium hyaluronate, potassium sorbate, sodium benzoate, xanthan gum, benzyl alcohol, sodium ascorbyl phosphate, limonene, retinyl palmitate, daucus carota sativa root, ascorbic acid, citric acid.</span></p>"
      }
    },
