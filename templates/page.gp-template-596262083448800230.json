    "gp_section_604527022630241085": {
      "settings": {
        "checksum": "1beb0619de97af61a05068818dcb17a3be5128c97db1495912ad61a0303a4354_1_1_1_0__1",
        "gg8OAUbi2i7_text": "<p>A bio-identical form of Vitamin A your skin recognizes as its own. Gentler than harsh retinol, it stimulates collagen production without redness or peeling.</p><p> </p><p><strong>BENEFITS:</strong></p><ul>\n<li>Stimulates collagen production</li>\n<li>Reduces wrinkles and fine lines</li>\n<li>Firms and tightens skin over time</li>\n</ul>",
        "ggJZcA19iP2_label": "<p>ITALIAN OIL OLIVE</p>",
        "ggPFK24HeWo_text": "<span style=\"color:#17162E;\">Anti-aging ingredients. Dermatologist Approved.</span>",
        "ggSdgHI-XG9_text": "<p>A powerful antioxidant sourced from organic groves in Marche, Italy. Protects your skin barrier from environmental damage while deeply nourishing overnight.</p><p> </p><p><strong>BENEFITS:</strong></p><ul>\n<li>Shields skin from daily damage</li>\n<li>Nourishes without clogging pores</li>\n<li>Restores natural moisture balance</li>\n</ul>",
        "ggX2RyGbGcy_text": "<p>A low molecular weight form of hyaluronic acid that penetrates deeper than regular HA. Fills wrinkles from within for visible plumping.</p><p> </p><p><strong>BENEFITS:</strong></p><ul>\n<li>Penetrates deeper than standard HA</li>\n<li>Fills wrinkles from the inside</li>\n<li>Plumper, more hydrated skin</li>\n</ul>",
        "gg_NT4F7gb__text": "<p>They don't just hydrate, but actively fight the signs of time</p>",
        "ggckoHfnEtE_label": "<p><strong>SODIUM HYALURONATE</strong></p>",
        "gghRgus9t5T_label": "<p>RETINYL PALMITATE</p>",
        "ggvIaVrCtZD_text": "<p><span style=\"background-color:transparent;color:#000000;font-size:11pt;\">aqua, propylene glycol, glycerin, caprylic/capric triglyceride, hydrogenated ethylhexyl olivate, glyceryl stearate se, aloe barbadensis leaf juice, sodium polyacrylate, phenoxyethanol, hydrogenated olive oil unsaponifiables, tocopherol, tetrasodium glutamate diacetate, urea, trehalose, ethylhexylglycerin, hydrolyzed rice protein, lavandula angustifolia oil, propanediol, sorbitol, linalool, lecithin, olive oil peg-8 esters, helianthus annuus seed oil, tocopheryl acetate, hydroxyethylcellulose, sodium hyaluronate, potassium sorbate, sodium benzoate, xanthan gum, benzyl alcohol, sodium ascorbyl phosphate, limonene, retinyl palmitate, daucus carota sativa root, ascorbic acid, citric acid</span></p>",
        "ggwIYFUtntp_childItem_0": "<p>Full Ingredient List</p>"
      },
      "type": "gp-section-604527022630241085"
    },
    "gp_section_604527068046164797": {
      "settings": {
        "checksum": "02ebce7e16f82f776e4b2d703756656da95a090b68e0376931ae2acd64ed25b7_1_1_1_0__1"
      },
      "type": "gp-section-604527068046164797"
