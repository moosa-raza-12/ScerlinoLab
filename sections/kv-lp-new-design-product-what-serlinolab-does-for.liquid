{{ 'kv-lp-new-design-product-what-serlinolab-does-for.css' | asset_url | stylesheet_tag }}

<section class="lp-what-serlinolab" id="lp-section-{{ section.id }}" style="--mobile-height: {{ section.settings.mobile_height }}px;">
  {%- if section.settings.image_desktop != blank -%}
    <picture class="lp-what-serlinolab__bg">
      {%- if section.settings.image_mobile != blank -%}
        <source media="(max-width: 767px)" srcset="{{ section.settings.image_mobile | image_url: width: 800 }}">
      {%- endif -%}
      <img src="{{ section.settings.image_desktop | image_url: width: 2000 }}" alt="{{ section.settings.heading | escape }}" loading="lazy" width="{{ section.settings.image_desktop.width }}" height="{{ section.settings.image_desktop.height }}">
    </picture>
  {%- endif -%}

  <div class="lp-what-serlinolab__overlay"></div>

  <div class="lp-what-serlinolab__container">
    <div class="lp-what-serlinolab__content">
      <h2 class="lp-what-serlinolab__heading">{{ section.settings.heading | newline_to_br }}</h2>
      
      <div class="lp-what-serlinolab__benefits-grid">
        {%- for block in section.blocks -%}
          <div class="lp-benefit-item" {{ block.shopify_attributes }}>
            <div class="lp-benefit-item__icon">
              {%- if block.settings.icon_svg != blank -%}
                {{ block.settings.icon_svg }}
              {%- else -%}
                <div class="lp-benefit-item__icon-placeholder"></div>
              {%- endif -%}
            </div>
            <p class="lp-benefit-item__title">{{ block.settings.title | escape }}</p>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>

  <div class="lp-trustpilot-bar">
    <div class="lp-trustpilot-bar__inner">
      <div class="lp-trustpilot-logo">
        <svg width="92" height="18" viewBox="0 0 92 18" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M8.6803 17.2367L17.2275 17.2275L8.6803 11.4132L0 17.2275L8.6803 17.2367Z" fill="#00B67A"/>
          <path d="M17.2275 17.2275L13.847 6.13477L8.6803 11.4132L17.2275 17.2275Z" fill="#00B67A"/>
          <path d="M13.847 6.13477L8.6803 0L3.51367 6.13477H13.847Z" fill="#00B67A"/>
          <path d="M3.51367 6.13477L0 17.2275L8.6803 11.4132L3.51367 6.13477Z" fill="#00B67A"/>
          <path d="M8.6803 11.4132L13.847 6.13477H3.51367L8.6803 11.4132Z" fill="#00B67A"/>
          <path d="M29.5 14H27.5V7H25V5.5H32V7H29.5V14ZM36.5 7.5C36.5 6.5 35.8 5.5 34.5 5.5H32.5V14H34.5V10.5C35 10.5 35.5 10.5 36 10H36.5V7.5ZM34.5 9H34V7H34.5C35 7 35.5 7 35.5 7.5V8.5C35.5 9 35 9 34.5 9ZM43 11.5C43 13 42 14 40.5 14C39 14 38 13 38 11.5V5.5H39.5V11.5C39.5 12.5 40 13 40.5 13C41 13 41.5 12.5 41.5 11.5V5.5H43V11.5ZM49 13.5C48.5 13.8 47.8 14 47.2 14C45.5 14 44.5 13 44.5 11.5H46C46 12.5 46.5 13 47.2 13C47.8 13 48.2 12.8 48.2 12.5C48.2 12.2 48 12 47.5 11.8L46.5 11.4C45.5 11 44.8 10.5 44.8 9.5C44.8 8 45.8 7 47.2 7C48.5 7 49.5 7.5 49.5 8.5H48C48 8 47.5 7.8 47 7.8C46.5 7.8 46.2 8 46.2 8.3C46.2 8.6 46.5 8.8 47 9L48 9.4C49 9.8 49.8 10.5 49.8 11.5C49.8 12.8 49 13.5 49 13.5ZM55.5 14H54V7H52V5.5H57.5V7H55.5V14ZM63.5 5.5H66V14H64.5V12.5C64 13.5 63 14 62 14C60.5 14 59.5 13 59.5 11.5V5.5H61V11.5C61 12.5 61.5 13 62 13C62.5 13 63.5 12.5 63.5 11.5V5.5ZM71.5 5.5V14H70V5.5H71.5ZM77.5 5.5V14H76V5.5H77.5ZM83 14H81.5V5.5H84.5C86 5.5 87 6.5 87 8C87 9.5 86 10.5 84.5 10.5H83V14ZM83 9H84.5C85.2 9 85.5 8.5 85.5 8C85.5 7.5 85.2 7 84.5 7H83V9ZM92 11.5C92 13 91 14 89.5 14C88 14 87 13 87 11.5C87 10 88 9 89.5 9C91 9 92 10 92 11.5ZM88.5 11.5C88.5 12.5 89 13 89.5 13C90 13 90.5 12.5 90.5 11.5C90.5 10.5 90 10 89.5 10C89 10 88.5 10.5 88.5 11.5Z" fill="white"/>
        </svg>
      </div>
      <span class="lp-trustpilot-rating">{{ section.settings.trustpilot_score }}</span>
      <span class="lp-trustpilot-divider">|</span>
      <span class="lp-trustpilot-reviews">{{ section.settings.trustpilot_reviews }}</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SerlinoLab Science",
  "settings": [
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "What SerlinoLab does\nfor your skin"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Background Image (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Background Image (Mobile)"
    },
    {
      "type": "text",
      "id": "trustpilot_score",
      "label": "Trustpilot Score",
      "default": "4.6 Excellent"
    },
    {
      "type": "text",
      "id": "trustpilot_reviews",
      "label": "Trustpilot Reviews",
      "default": "3,439+ reviews"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Section Height (Mobile)",
      "info": "Height in pixels for screens up to 780px",
      "min": 300,
      "max": 1000,
      "step": 10,
      "default": 740,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon (SVG Code)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SerlinoLab Science",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "title": "Visible wrinkle reduction*"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Firmer feel in 2 weeks*"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Softer, more elastic skin*"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Rapid absorption"
          }
        }
      ]
    }
  ]
}
{% endschema %}