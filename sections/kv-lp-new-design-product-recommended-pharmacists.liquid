        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "info": "Upload a video. The poster image above will be used as the thumbnail. Leave empty for a static image card."
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role/Title"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pharmacist Recommends",
      "settings": {
        "heading": "Recommended by\npharmacists in Italy"
