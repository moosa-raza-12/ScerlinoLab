{{ 'kv-lp-new-design-product-results-others-notice.css' | asset_url | stylesheet_tag }}

<section class="lp-results-notice" id="lp-section-{{ section.id }}">
  <div class="lp-results-notice__container" id="lp-results-notice-container">
    {% if section.settings.title != blank %}
      <header class="lp-results-notice__header">
        <h2 class="lp-results-notice__title">{{ section.settings.title }}</h2>
      </header>
    {% endif %}

    <div class="lp-results-notice__list-wrapper">
      <div class="lp-results-notice__list" id="lp-results-notice-list-{{ section.id }}">
        {% for block in section.blocks %}
          <div class="lp-results-notice__card" {{ block.shopify_attributes }}>
            <div class="lp-results-notice__media">
              <div class="lp-results-notice__images-grid">
                <div class="lp-results-notice__img-box">
                  {% if block.settings.image_before != blank %}
                    {{ block.settings.image_before | image_url: width: 400 | image_tag: loading: 'lazy', class: 'lp-results-notice__img' }}
                  {% else %}
                    {{ 'image' | placeholder_svg_tag: 'lp-results-notice__placeholder' }}
                  {% endif %}
                  <span class="lp-results-notice__label">{{ block.settings.label_before }}</span>
                </div>
                <div class="lp-results-notice__img-box">
                  {% if block.settings.image_after != blank %}
                    {{ block.settings.image_after | image_url: width: 400 | image_tag: loading: 'lazy', class: 'lp-results-notice__img' }}
                  {% else %}
                    {{ 'image' | placeholder_svg_tag: 'lp-results-notice__placeholder' }}
                  {% endif %}
                  <span class="lp-results-notice__label">{{ block.settings.label_after }}</span>
                </div>
              </div>
            </div>

            <div class="lp-results-notice__info">
              <h3 class="lp-results-notice__reviewer-name">{{ block.settings.reviewer_name }}</h3>
              <p class="lp-results-notice__reviewer-subtitle">{{ block.settings.reviewer_subtitle }}</p>
              <p class="lp-results-notice__testimonial">
                {{ block.settings.testimonial }}
              </p>
              <div class="lp-results-notice__tags">
                {% if block.settings.tag_1 != blank %}
                  <span class="lp-results-notice__tag">{{ block.settings.tag_1 }}</span>
                {% endif %}
                {% if block.settings.tag_2 != blank %}
                  <span class="lp-results-notice__tag">{{ block.settings.tag_2 }}</span>
                {% endif %}
                 {% if block.settings.tag_3 != blank %}
                  <span class="lp-results-notice__tag">{{ block.settings.tag_3 }}</span>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="lp-results-notice__nav">
      <button class="lp-results-notice__arrow lp-results-notice__arrow--prev" data-nav="prev" aria-label="Previous">
        <svg width="20" height="16" viewBox="0 0 20 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M8 1L1 8L8 15M1 8H19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="lp-results-notice__dots">
        {% for block in section.blocks %}
          <span class="lp-results-notice__dot{% if forloop.first %} is-active{% endif %}" data-dot="{{ forloop.index0 }}"></span>
        {% endfor %}
      </div>
      <button class="lp-results-notice__arrow lp-results-notice__arrow--next" data-nav="next" aria-label="Next">
        <svg width="20" height="16" viewBox="0 0 20 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 1L19 8L12 15M19 8H1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>

<script>
(function() {
  var section = document.querySelector('#lp-section-{{ section.id }}');
  if (!section) return;

  var listWrapper = section.querySelector('.lp-results-notice__list-wrapper');
  var cards = section.querySelectorAll('.lp-results-notice__card');
  var dots = section.querySelectorAll('[data-dot]');
  var prevBtn = section.querySelector('[data-nav="prev"]');
  var nextBtn = section.querySelector('[data-nav="next"]');
  var totalCards = cards.length;

  if (!listWrapper || totalCards === 0) return;

  function getGap() {
    var list = section.querySelector('.lp-results-notice__list');
    if (!list) return 20;
    return parseFloat(getComputedStyle(list).gap) || 20;
  }

  function getCardWidth() {
    if (cards.length === 0) return 0;
    return cards[0].offsetWidth + getGap();
  }

  function getCurrentCardIndex() {
    var cardWidth = getCardWidth();
    if (cardWidth === 0) return 0;
    var scrollPosition = listWrapper.scrollLeft;
    var index = Math.round(scrollPosition / cardWidth);
    return Math.min(Math.max(0, index), totalCards - 1);
  }

  function updateButtonStates() {
    var currentIndex = getCurrentCardIndex();

    if (currentIndex === 0) {
      prevBtn.classList.remove('is-active');
    } else {
      prevBtn.classList.add('is-active');
    }

    if (currentIndex === totalCards - 1) {
      nextBtn.classList.remove('is-active');
    } else {
      nextBtn.classList.add('is-active');
    }
  }

  function updateDots() {
    var currentIndex = getCurrentCardIndex();
    dots.forEach(function(dot, i) {
      dot.classList.toggle('is-active', i === currentIndex);
    });
  }

  function scrollToCard(index, smooth) {
    if (index < 0) index = 0;
    if (index >= totalCards) index = totalCards - 1;

    var cardWidth = getCardWidth();
    if (cardWidth === 0) return;

    var scrollPosition = index * cardWidth;

    listWrapper.scrollTo({
      left: scrollPosition,
      behavior: smooth ? 'smooth' : 'auto'
    });
  }

  var scrollTimeout;
  listWrapper.addEventListener('scroll', function() {
    clearTimeout(scrollTimeout);
    scrollTimeout = setTimeout(function() {
      updateDots();
      updateButtonStates();
    }, 50);
  });

  if (prevBtn) {
    prevBtn.addEventListener('click', function() {
      var currentIndex = getCurrentCardIndex();
      if (currentIndex > 0) {
        scrollToCard(currentIndex - 1, true);
      }
    });
  }

  if (nextBtn) {
    nextBtn.addEventListener('click', function() {
      var currentIndex = getCurrentCardIndex();
      if (currentIndex < totalCards - 1) {
        scrollToCard(currentIndex + 1, true);
      }
    });
  }

  dots.forEach(function(dot, index) {
    dot.addEventListener('click', function() {
      scrollToCard(index, true);
    });
  });

  var touchStartX = 0;
  var touchEndX = 0;

  listWrapper.addEventListener('touchstart', function(e) {
    touchStartX = e.changedTouches[0].screenX;
  });

  listWrapper.addEventListener('touchend', function(e) {
    touchEndX = e.changedTouches[0].screenX;
    var swipeThreshold = 50;
    var currentIndex = getCurrentCardIndex();

    if (touchEndX < touchStartX - swipeThreshold && currentIndex < totalCards - 1) {
      scrollToCard(currentIndex + 1, true);
    } else if (touchEndX > touchStartX + swipeThreshold && currentIndex > 0) {
      scrollToCard(currentIndex - 1, true);
    }
  });

  document.addEventListener('keydown', function(e) {
    var rect = section.getBoundingClientRect();
    var isVisible = rect.top < window.innerHeight && rect.bottom > 0;

    if (!isVisible) return;

    var currentIndex = getCurrentCardIndex();

    if (e.key === 'ArrowLeft' && currentIndex > 0) {
      scrollToCard(currentIndex - 1, true);
      e.preventDefault();
    } else if (e.key === 'ArrowRight' && currentIndex < totalCards - 1) {
      scrollToCard(currentIndex + 1, true);
      e.preventDefault();
    }
  });

  var resizeTimer;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function() {
      var currentIndex = getCurrentCardIndex();
      scrollToCard(currentIndex, false);
      updateButtonStates();
      updateDots();
    }, 250);
  });

  function initialize() {
    scrollToCard(0, false);
    updateButtonStates();
    updateDots();
  }

  initialize();
})();
</script>
</section>

{% schema %}
{
  "name": "Results Notice",
  "settings": [
    {
      "type": "textarea",
      "id": "title",
      "label": "Section Title",
      "default": "Results other will\nnotice."
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_before",
          "label": "Image Before"
        },
        {
          "type": "image_picker",
          "id": "image_after",
          "label": "Image After"
        },
        {
          "type": "text",
          "id": "label_before",
          "label": "Label Before",
          "default": "Before"
        },
        {
          "type": "text",
          "id": "label_after",
          "label": "Label After",
          "default": "Month 5"
        },
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "Reviewer Name",
          "default": "Jason"
        },
        {
          "type": "text",
          "id": "reviewer_subtitle",
          "label": "Reviewer Subtitle",
          "default": "Before vs. 5 months using SerlinoLab"
        },
        {
          "type": "textarea",
          "id": "testimonial",
          "label": "Testimonial",
          "default": "After a few weeks my skin felt smoother and more firm. By week 8, the lines looked softer and my face looked noticeably more refreshed - without any greasy feel."
        },
        {
          "type": "text",
          "id": "tag_1",
          "label": "Tag 1",
          "default": "✨ Smoother texture"
        },
        {
          "type": "text",
          "id": "tag_2",
          "label": "Tag 2",
          "default": "💪 Firmer feel"
        },
        {
          "type": "text",
          "id": "tag_3",
          "label": "Tag 3",
          "default": "💪 Firmer feel"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Results Notice",
      "blocks": [
        {
          "type": "review"
        },
        {
          "type": "review"
        },
        {
          "type": "review"
        }
      ]
    }
  ]
}
{% endschema %}
