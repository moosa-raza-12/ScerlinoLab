<style>
  /* html, body {
    overflow-x: hidden;
    max-width: 100vw;
  } */
  
  #shopify-section-{{ section.id }} {
    max-width: 100%;
    overflow: hidden;
    box-sizing: border-box;
  }
  
  .section-{{ section.id }}.custom-marquee {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    height: {{ section.settings.marquee_height }}px;
    width: 100%;
    max-width: 100%;
    overflow: hidden;
    background: {{ section.settings.colorBackground }};
    color: {{ section.settings.colorText }};
    position: relative;
    box-sizing: border-box;
  }
  
  .section-{{ section.id }} .marquee-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    white-space: nowrap;
    width: 100%;
    max-width: 100%;
    padding: 6px 20px;
    box-sizing: border-box;
    overflow: hidden;
  }
  
  .section-{{ section.id }} .marquee-icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    display: none;
  }
  
  .section-{{ section.id }} .marquee-icon svg {
    width: 18px;
    height: 18px;
    fill: {{ section.settings.colorText }};
  }
  
  .section-{{ section.id }} .marquee-text-content {
    display: flex !important;
    flex-direction: column !important;
    align-items: center;
    justify-content: center;
    gap: 1px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0px;
    line-height: 1.2;
    white-space: normal !important;
  }
  
  .section-{{ section.id }} .marquee-text-content.highlight-below {
    flex-direction: column-reverse;
  }
  
  .section-{{ section.id }} .marquee-text-highlight {
    display: block;
    width: 100%;
    text-align: center;
    font-weight: 500;
    color: {{ section.settings.colorText }};
    font-size: 14px;
    line-height: 1.2;
    font-family: "ABC Repro" !important;
    /* opacity: 0.85; */
    white-space: nowrap;
  }
  
  .section-{{ section.id }} .marquee-text-regular {
    display: block;
    width: 100%;
    text-align: center;
    font-weight: 600;
    color: {{ section.settings.colorText }};
    font-size: 14px;
    line-height: 1.2;
    white-space: nowrap;
  }
  
  .section-{{ section.id }} .marquee-countdown {
    display: flex;
      align-items: center;
      gap: 0px;
      /* margin-left: 8px; */
      flex-shrink: 0;
      background-color: rgba(255, 255, 255, 0.20);
      border-radius: 4px;
      padding: 6px 8px;
      height: 32px;
  }
  
  .section-{{ section.id }} .countdown-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    /* background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 4px; */
    padding: 3px 6px;
    min-width: 32px;
    line-height: 1;
  }
  
  .section-{{ section.id }} .countdown-number {
    font-size: 14px;
    font-weight: 700;
    color: {{ section.settings.colorText }};
    font-weight: 500;
  line-height: 12px;
  }
  
  .section-{{ section.id }} .countdown-label {
    font-size: 8px;
    font-weight: 350;
    color: {{ section.settings.colorText }};
    opacity: 1;
    text-transform: uppercase;
    letter-spacing: 0px;
    line-height: 1.2;
    margin-top: 4px;
  }
  
  .section-{{ section.id }} .countdown-separator {
    font-size: 14px;
    /* font-weight: 700; */
    color: {{ section.settings.colorText }};
    opacity: 1;
    padding: 0 1px;
    margin-bottom: 6px;
  }
  
  .section-{{ section.id }} .marquee-link-icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    margin-left: 18px;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }
  
  .section-{{ section.id }} .marquee-link-icon:hover {
    opacity: 1;
  }
  
  .section-{{ section.id }}.custom-marquee a {
    color: {{ section.settings.colorText }};
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    max-width: 100%;
    overflow: hidden;
    box-sizing: border-box;
  }
  
  @media screen and (max-width: 749px) {
    .section-{{ section.id }}.custom-marquee {
      display: flex;
      padding: 8px 12px;
      justify-content: center;
      align-items: center;
      background-color: #17162E;
      height: {{ section.settings.marquee_height }}px;
      width: 100%;
      max-width: 100%;
      box-sizing: border-box;
      overflow: hidden;
    }
  
    .section-{{ section.id }} .marquee-inner {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 10px;
      white-space: normal;
      padding: 0;
      width: 100%;
      max-width: 100%;
      box-sizing: border-box;
      overflow: hidden;
    }
  
    .section-{{ section.id }} .marquee-text-content {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      font-size: 12px;
      font-weight: 500;
      letter-spacing: 0px;
      gap: 1px;
      flex-shrink: 1;
      min-width: 0;
      overflow: hidden;
    }
  
    .section-{{ section.id }} .marquee-text-content.highlight-below {
      flex-direction: column-reverse;
    }
  
    .section-{{ section.id }} .marquee-text-highlight {
      font-size: 12px;
    }
  
    .section-{{ section.id }} .marquee-text-regular {
      font-size: 12px;
    }
  
    .section-{{ section.id }} .marquee-text-content span {
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 100%;
    }
  
    .section-{{ section.id }} .marquee-countdown {
      padding: 4px 0px;
      gap: 0px;
      height: auto;
      flex-shrink: 0;
    }
  
    .section-{{ section.id }} .countdown-block {
      padding: 2px 4px;
      min-width: 24px;
    }
  
    .section-{{ section.id }} .countdown-number {
      font-size: 12px;
      line-height: 12px;
    }
  
    .section-{{ section.id }} .countdown-label {
      font-size: 6px;
      font-weight: 350;
      margin-top: 2px;
    }
  
    .section-{{ section.id }} .countdown-separator {
      font-size: 12px;
      margin-bottom: 4px;
    }
  
    .section-{{ section.id }} .marquee-link-icon {
      margin-left: 0;
    }
  }
  </style>
  
  <div class="section-{{ section.id }} custom-marquee" role="region">
    {% if section.settings.link != blank -%}
      <a href="{{ section.settings.link }}">
    {% endif -%}
      <div class="marquee-inner">
        {%- if section.settings.show_icon -%}
          <span class="marquee-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M12 2L13.09 8.26L18 6L14.74 10.91L21 12L14.74 13.09L18 18L13.09 15.74L12 22L10.91 15.74L6 18L9.26 13.09L3 12L9.26 10.91L6 6L10.91 8.26L12 2Z"/>
            </svg>
          </span>
        {%- endif -%}
  
        <div class="marquee-text-content {% if section.settings.highlight_position == 'below' %}highlight-below{% endif %}">
          {%- if section.settings.highlight_text != blank -%}
            <span class="marquee-text-highlight">{{ section.settings.highlight_text | escape }}</span>
          {%- endif -%}
          {%- if section.settings.main_text != blank -%}
            <span class="marquee-text-regular">{{ section.settings.main_text | escape }}</span>
          {%- endif -%}
        </div>
  
        {%- if section.settings.enable_countdown -%}
          <div class="marquee-countdown" data-countdown-repeat-days="{{ section.settings.countdown_repeat_days }}">
            <div class="countdown-block">
              <span class="countdown-number" data-days>00</span>
              <span class="countdown-label">DAYS</span>
            </div>
            <span class="countdown-separator">:</span>
            <div class="countdown-block">
              <span class="countdown-number" data-hours>00</span>
              <span class="countdown-label">HRS</span>
            </div>
            <span class="countdown-separator">:</span>
            <div class="countdown-block">
              <span class="countdown-number" data-minutes>00</span>
              <span class="countdown-label">MIN</span>
            </div>
            <span class="countdown-separator">:</span>
            <div class="countdown-block">
              <span class="countdown-number" data-seconds>00</span>
              <span class="countdown-label">SEC</span>
            </div>
          </div>
        {%- endif -%}
  
        <span class="marquee-link-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 8 8" fill="none">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M1 2H3.5V3H1V7H5V4.5H6V7C6 7.26522 5.89464 7.51957 5.70711 7.70711C5.51957 7.89464 5.26522 8 5 8H1C0.734784 8 0.48043 7.89464 0.292893 7.70711C0.105357 7.51957 0 7.26522 0 7V3C0 2.73478 0.105357 2.48043 0.292893 2.29289C0.48043 2.10536 0.734784 2 1 2ZM6.307 1H4V0H8V4H7V1.721L4.332 4.389L3.625 3.682L6.307 1Z" fill="white"/>
            </svg>
          </span>
      </div>
    {% if section.settings.link != blank -%}
      </a>
    {% endif -%}
  </div>
  
  {%- if section.settings.enable_countdown -%}
  <script>
    (function() {
      const countdownEl = document.querySelector('.section-{{ section.id }} .marquee-countdown');
      if (!countdownEl) return;

      var repeatDays = Math.max(1, parseInt(countdownEl.dataset.countdownRepeatDays, 10) || 3);
      var dayMs = 24 * 60 * 60 * 1000;

      const daysEl = countdownEl.querySelector('[data-days]');
      const hoursEl = countdownEl.querySelector('[data-hours]');
      const minutesEl = countdownEl.querySelector('[data-minutes]');
      const secondsEl = countdownEl.querySelector('[data-seconds]');

      function pad(n) { return n < 10 ? '0' + n : n; }

      function getTargetMs() {
        var intervalMs = repeatDays * dayMs;
        var nowMs = Date.now();
        return Math.floor(nowMs / intervalMs) * intervalMs + intervalMs;
      }

      function updateCountdown() {
        var targetDate = getTargetMs();
        var now = new Date().getTime();
        var diff = targetDate - now;

        if (diff <= 0 || isNaN(targetDate)) {
          daysEl.textContent = '00';
          hoursEl.textContent = '00';
          minutesEl.textContent = '00';
          secondsEl.textContent = '00';
          return;
        }

        var days = Math.floor(diff / (1000 * 60 * 60 * 24));
        var hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        var minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        var seconds = Math.floor((diff % (1000 * 60)) / 1000);

        daysEl.textContent = pad(days);
        hoursEl.textContent = pad(hours);
        minutesEl.textContent = pad(minutes);
        secondsEl.textContent = pad(seconds);
      }

      updateCountdown();
      setInterval(updateCountdown, 1000);
    })();
  </script>
  {%- endif -%}
  
  {% schema %}
  {
    "name": "Marquee Announcement",
    "settings": [
      {
        "type": "color",
        "id": "colorBackground",
        "label": "Background color",
        "default": "#1a1a2e"
      },
      {
        "type": "color",
        "id": "colorText",
        "label": "Text color",
        "default": "#ffffff"
      },
      {
        "type": "url",
        "id": "link",
        "label": "Link"
      },
      {
        "type": "range",
        "id": "marquee_height",
        "min": 24,
        "max": 80,
        "step": 2,
        "default": 44,
        "label": "Bar height"
      },
      {
        "type": "range",
        "id": "font_size",
        "min": 10,
        "max": 24,
        "step": 1,
        "default": 13,
        "label": "Font size"
      },
      {
        "type": "text",
        "id": "highlight_text",
        "label": "Highlight text (small)",
        "default": "❄️ Winter Sale",
        "info": "Smaller text line (e.g. sale name, label)"
      },
      {
        "type": "text",
        "id": "main_text",
        "label": "Main text (large)",
        "default": "47% off and free shipping",
        "info": "Larger prominent text line"
      },
      {
        "type": "select",
        "id": "highlight_position",
        "label": "Highlight text position",
        "default": "top",
        "options": [
          {
            "value": "top",
            "label": "Top (above main text)"
          },
          {
            "value": "below",
            "label": "Below (under main text)"
          }
        ]
      },
      {
        "type": "checkbox",
        "id": "show_icon",
        "label": "Show icon before text",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_countdown",
        "label": "Enable countdown timer",
        "default": true
      },
      {
        "type": "range",
        "id": "countdown_repeat_days",
        "min": 1,
        "max": 30,
        "step": 1,
        "default": 3,
        "label": "Countdown repeats every (days)",
        "info": "Timer resets after each interval. Deadlines align to repeating windows in UTC (same moment for all visitors)."
      }
    ],
    "blocks": [
      {
        "type": "text",
        "name": "Text",
        "limit": 10,
        "settings": [
          {
            "type": "text",
            "id": "new_text",
            "default": "Winter sale",
            "label": "Text"
          },
          {
            "type": "select",
            "id": "text_style",
            "label": "Text style",
            "default": "highlight",
            "options": [
              {
                "value": "highlight",
                "label": "Bold / Highlight"
              },
              {
                "value": "regular",
                "label": "Regular"
              }
            ]
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Marquee Announcement",
        "blocks": [
          {
            "type": "text",
            "settings": {
              "new_text": "❄ Winter sale",
              "text_style": "highlight"
            }
          },
          {
            "type": "text",
            "settings": {
              "new_text": "Flat 47% off and free shipping",
              "text_style": "regular"
            }
          }
        ]
      }
    ]
  }
  {% endschema %}
  