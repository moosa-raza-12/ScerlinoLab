{% schema %}
{
  "name": "Pharmacist Recommends",
  "settings": [
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Recommended by pharmacists in Italy"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Poster Image",
          "info": "This image is shown as the thumbnail. When a video is also provided, clicking it will play the video."
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "info": "Upload a video. The poster image above will be used as the thumbnail. Leave empty for a static image card."
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role/Title"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pharmacist Recommends",
