    "gp_section_604526907270103723": {
      "settings": {
        "checksum": "75b2e49ebb4a767ee442e4d68c4c1ff59a4d81354b096367d990998717e5b785_1_1_1_0__1",
        "ggjnjGqvwsQ_text": "<span style=\"color:#17162E;\">The Science Behind SerlinoLab</span>",
        "ggtrwMkUq6Y_text": "<p>Every year after 40 men <strong>lose 1% of collagen</strong>. SerlinoLab helps counteract this process for a more <strong>toned </strong>and <strong>youthful</strong> face.</p>"
      },
      "type": "gp-section-604526907270103723"
    },
    "gp_section_604526943877989345": {
      "settings": {
        "checksum": "1c1d7945a7ab8a3ec4c0042f2fcc16c5527a6e134199dbba1795128894784a76_1_1_1_0__1",
        "gg0ePjErDKy_text": "<p>*Tests conducted on 124 men for 60 days</p>",
        "ggF__iQAvkK_text": "From the First Application,<br><span style=\"color:#17162E;\">Softer and More Elastic Skin</span>",
        "ggIbFdW3cgu_text": "<p>More compact and toned skin in <strong>2 weeks</strong></p>",
        "ggnuE9XrNLv_text": "<span style=\"color:#17162E;\"><strong>From the First Application, Softer and More Elastic Skin</strong></span>",
        "ggocNFlXiw7_text": "<p>Visible <strong>wrinkle reduction*</strong></p>",
        "ggvn2Lb-gZz_text": "<p>Confirms rapid absorption <strong>without greasy effect</strong></p>"
      },
      "type": "gp-section-604526943877989345"
    },
    "gp_section_604526967986848427": {
      "settings": {
        "checksum": "d6a042690fe9e529c07a314f9522807be371262c72d6d920d8efd609b931d650_1_1_1_0__1"
      },
