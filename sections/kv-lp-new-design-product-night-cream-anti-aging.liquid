{{ 'kv-lp-new-design-product-night-cream-anti-aging.css' | asset_url | stylesheet_tag }}

<style>
.lp-kaching-bridge {
  position: fixed !important;
  left: 0 !important;
  bottom: -9999px !important;
  width: 400px;
  height: 400px;
  overflow: hidden;
  pointer-events: none;
  opacity: 0.001;
  z-index: -1;
}
.lp-product-gallery__thumbs {
  display: flex;
  gap: 8px;
  align-items: center;
  overflow-x: auto;
  scroll-behavior: smooth;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.lp-product-gallery__thumbs::-webkit-scrollbar {
  display: none;
}

#lp-sticky-atc {
    display: none;
}
.lp-product-gallery__thumb {
  display: block;
  padding: 0;
  border: 2px solid transparent;
  border-radius: 8px;
  background: none;
  cursor: pointer;
  overflow: hidden;
  opacity: 0.5;
  transition: opacity .2s, border-color .2s;
  flex-shrink: 0;
}
.lp-product-gallery__thumb.active {
  border-color: #1A2A49;
  opacity: 1;
}
.lp-product-gallery__thumb:hover {
  opacity: 1;
}
.lp-product-gallery__thumb-img {
  display: block;
  width: 60px;
  height: 60px;
  object-fit: cover;
  border-radius: 6px;
}
.lp-testimonials__slider {
  scroll-behavior: smooth;
  -webkit-overflow-scrolling: touch;
}
.lp-testimonials__scroll-bar {
  position: relative;
  height: 4px;
  border-radius: 2px;
  background: #e0e0e0;
  overflow: hidden;
}
.lp-testimonials__scroll-thumb {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  border-radius: 2px;
  background: #1A2A49;
  min-width: 8%;
  transition: width .15s ease-out;
}

@media (max-width: 767.98px) { 

    #lp-sticky-atc {
        display: block;
    }
 }
</style>

<section class="lp-product-details" data-section-id="{{ section.id }}" data-product-url="{{ product.url | within: collection }}">
  <div class="lp-product-details__container">
    {% comment %} Gallery Section {% endcomment %}
    <div class="lp-product-gallery">
      <div class="lp-product-gallery__main">
        {%- assign extra_image_count = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'gallery_image' and block.settings.image != blank -%}
            {%- assign extra_image_count = extra_image_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
   {%- assign total_slides = extra_image_count -%}
        {%- assign slide_index = 0 -%}

        <div class="lp-product-gallery__track" id="GalleryTrack-{{ section.id }}">
          {% comment %} {% if product.images.size > 0 %}
            {% for image in product.images %}
              {%- assign img_alt = image.alt | default: product.title -%}
              <div class="lp-product-gallery__item{% if slide_index == 0 %} active{% endif %}">
                <img
                  src="{{ image | image_url: width: 800 }}"
                  alt="{{ img_alt | escape }}"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                  class="lp-product-gallery__img"
                >
              </div>
              {%- assign slide_index = slide_index | plus: 1 -%}
            {% endfor %}
          {% endif %} {% endcomment %}

          {% for block in section.blocks %}
            {% if block.type == 'gallery_image' and block.settings.image != blank %}
              {%- assign extra_alt = block.settings.image.alt | default: product.title -%}
            <div class="lp-product-gallery__item{% if forloop.first and product.images.size == 0 %} active{% endif %}" {{ block.shopify_attributes }}>
                <img
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  alt="{{ extra_alt | escape }}"
                  loading="lazy"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                  class="lp-product-gallery__img"
                >
              </div>
              {%- assign slide_index = slide_index | plus: 1 -%}
            {% endif %}
          {% endfor %}

          {% if total_slides == 0 %}
            <div class="lp-product-gallery__item active">
              {{ 'product-1' | placeholder_svg_tag: 'lp-product-gallery__img' }}
            </div>
          {% endif %}
        </div>
        
        {% if total_slides > 1 %}
          <div class="lp-product-gallery__nav">
            <button class="lp-product-gallery__arrow lp-product-gallery__arrow--prev" aria-label="Previous">
              <svg class="lp-product-gallery__icon-active" width="20" height="16" viewBox="0 0 20 16" fill="none"><path d="M8 1L1 8L8 15M1 8H19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <svg class="lp-product-gallery__icon-disabled" xmlns="http://www.w3.org/2000/svg" width="20" height="16" viewBox="0 0 20 16" fill="none">
                <path d="M8.18525 0C8.45091 0 8.67349 0.0879498 8.85299 0.263851C9.03249 0.432717 9.12224 0.647317 9.12224 0.907651C9.12224 1.0343 9.1007 1.15391 9.05762 1.26649C9.01454 1.3861 8.94992 1.48813 8.86376 1.57256L6.45127 3.97889L1.96015 8L6.45127 12.0211L8.86376 14.4274C8.94992 14.5119 9.01454 14.6104 9.05762 14.723C9.1007 14.8426 9.12224 14.9657 9.12224 15.0923C9.12224 15.3527 9.03249 15.5673 8.85299 15.7361C8.67349 15.912 8.45091 16 8.18525 16C8.056 16 7.93394 15.9754 7.81906 15.9261C7.697 15.8769 7.57853 15.796 7.46365 15.6834L0.323101 8.70712C0.1077 8.50308 0 8.26737 0 8C0 7.73263 0.1077 7.49692 0.323101 7.29288L7.48519 0.295514C7.69341 0.0985041 7.92676 0 8.18525 0ZM19.0522 7.06069C19.3323 7.06069 19.562 7.14864 19.7415 7.32454C19.9138 7.50044 20 7.72559 20 8C20 8.27441 19.9138 8.49956 19.7415 8.67546C19.562 8.85136 19.3323 8.93931 19.0522 8.93931L5.42811 8.93931L1.96015 8.72823C1.73757 8.71416 1.55807 8.6438 1.42165 8.51715C1.28523 8.3905 1.21702 8.21812 1.21702 8C1.21702 7.78892 1.28523 7.62005 1.42165 7.4934C1.55807 7.36675 1.73757 7.29288 1.96015 7.27177L5.42811 7.06069L19.0522 7.06069Z" fill="#1A2A49"/>
              </svg>
            </button>
            <div class="lp-product-gallery__thumbs">
              {%- assign thumb_index = 0 -%}
              {% for block in section.blocks %}
                {% if block.type == 'gallery_image' and block.settings.image != blank %}
                  <button class="lp-product-gallery__thumb{% if thumb_index == 0 %} active{% endif %}" data-index="{{ thumb_index }}" type="button" aria-label="Go to slide {{ thumb_index | plus: 1 }}">
                    <img
                      src="{{ block.settings.image | image_url: width: 120 }}"
                      alt="{{ block.settings.image.alt | default: product.title | escape }}"
                      loading="lazy"
                      width="60"
                      height="60"
                      class="lp-product-gallery__thumb-img"
                    >
                  </button>
                  {%- assign thumb_index = thumb_index | plus: 1 -%}
                {% endif %}
              {% endfor %}
            </div>
            <button class="lp-product-gallery__arrow lp-product-gallery__arrow--next" aria-label="Next">
              <svg class="lp-product-gallery__icon-active" width="20" height="16" viewBox="0 0 20 16" fill="none"><path d="M12 1L19 8L12 15M19 8H1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <svg class="lp-product-gallery__icon-disabled" xmlns="http://www.w3.org/2000/svg" width="20" height="16" viewBox="0 0 20 16" fill="none" style="transform: scaleX(-1);">
                <path d="M8.18525 0C8.45091 0 8.67349 0.0879498 8.85299 0.263851C9.03249 0.432717 9.12224 0.647317 9.12224 0.907651C9.12224 1.0343 9.1007 1.15391 9.05762 1.26649C9.01454 1.3861 8.94992 1.48813 8.86376 1.57256L6.45127 3.97889L1.96015 8L6.45127 12.0211L8.86376 14.4274C8.94992 14.5119 9.01454 14.6104 9.05762 14.723C9.1007 14.8426 9.12224 14.9657 9.12224 15.0923C9.12224 15.3527 9.03249 15.5673 8.85299 15.7361C8.67349 15.912 8.45091 16 8.18525 16C8.056 16 7.93394 15.9754 7.81906 15.9261C7.697 15.8769 7.57853 15.796 7.46365 15.6834L0.323101 8.70712C0.1077 8.50308 0 8.26737 0 8C0 7.73263 0.1077 7.49692 0.323101 7.29288L7.48519 0.295514C7.69341 0.0985041 7.92676 0 8.18525 0ZM19.0522 7.06069C19.3323 7.06069 19.562 7.14864 19.7415 7.32454C19.9138 7.50044 20 7.72559 20 8C20 8.27441 19.9138 8.49956 19.7415 8.67546C19.562 8.85136 19.3323 8.93931 19.0522 8.93931L5.42811 8.93931L1.96015 8.72823C1.73757 8.71416 1.55807 8.6438 1.42165 8.51715C1.28523 8.3905 1.21702 8.21812 1.21702 8C1.21702 7.78892 1.28523 7.62005 1.42165 7.4934C1.55807 7.36675 1.73757 7.29288 1.96015 7.27177L5.42811 7.06069L19.0522 7.06069Z" fill="#1A2A49"/>
              </svg>
            </button>
          </div>
        {% endif %}
      </div>
    </div>

    {% comment %} Info Section {% endcomment %}
    <div class="lp-product-info">
       <div class="lp-product-gallery__nav-mobile">
            <button class="lp-product-gallery__arrow lp-product-gallery__arrow--prev" aria-label="Previous">
              <svg class="lp-product-gallery__icon-active" width="20" height="16" viewBox="0 0 20 16" fill="none"><path d="M8 1L1 8L8 15M1 8H19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <svg class="lp-product-gallery__icon-disabled" xmlns="http://www.w3.org/2000/svg" width="20" height="16" viewBox="0 0 20 16" fill="none">
                <path d="M8.18525 0C8.45091 0 8.67349 0.0879498 8.85299 0.263851C9.03249 0.432717 9.12224 0.647317 9.12224 0.907651C9.12224 1.0343 9.1007 1.15391 9.05762 1.26649C9.01454 1.3861 8.94992 1.48813 8.86376 1.57256L6.45127 3.97889L1.96015 8L6.45127 12.0211L8.86376 14.4274C8.94992 14.5119 9.01454 14.6104 9.05762 14.723C9.1007 14.8426 9.12224 14.9657 9.12224 15.0923C9.12224 15.3527 9.03249 15.5673 8.85299 15.7361C8.67349 15.912 8.45091 16 8.18525 16C8.056 16 7.93394 15.9754 7.81906 15.9261C7.697 15.8769 7.57853 15.796 7.46365 15.6834L0.323101 8.70712C0.1077 8.50308 0 8.26737 0 8C0 7.73263 0.1077 7.49692 0.323101 7.29288L7.48519 0.295514C7.69341 0.0985041 7.92676 0 8.18525 0ZM19.0522 7.06069C19.3323 7.06069 19.562 7.14864 19.7415 7.32454C19.9138 7.50044 20 7.72559 20 8C20 8.27441 19.9138 8.49956 19.7415 8.67546C19.562 8.85136 19.3323 8.93931 19.0522 8.93931L5.42811 8.93931L1.96015 8.72823C1.73757 8.71416 1.55807 8.6438 1.42165 8.51715C1.28523 8.3905 1.21702 8.21812 1.21702 8C1.21702 7.78892 1.28523 7.62005 1.42165 7.4934C1.55807 7.36675 1.73757 7.29288 1.96015 7.27177L5.42811 7.06069L19.0522 7.06069Z" fill="#1A2A49"/>
              </svg>
            </button>
            <div class="lp-product-gallery__dots">
              {% for i in (1..total_slides) %}
                <span class="lp-product-gallery__dot{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}"></span>
              {% endfor %}
            </div>
            <button class="lp-product-gallery__arrow lp-product-gallery__arrow--next" aria-label="Next">
              <svg class="lp-product-gallery__icon-active" width="20" height="16" viewBox="0 0 20 16" fill="none"><path d="M12 1L19 8L12 15M19 8H1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              <svg class="lp-product-gallery__icon-disabled" xmlns="http://www.w3.org/2000/svg" width="20" height="16" viewBox="0 0 20 16" fill="none" style="transform: scaleX(-1);">
                <path d="M8.18525 0C8.45091 0 8.67349 0.0879498 8.85299 0.263851C9.03249 0.432717 9.12224 0.647317 9.12224 0.907651C9.12224 1.0343 9.1007 1.15391 9.05762 1.26649C9.01454 1.3861 8.94992 1.48813 8.86376 1.57256L6.45127 3.97889L1.96015 8L6.45127 12.0211L8.86376 14.4274C8.94992 14.5119 9.01454 14.6104 9.05762 14.723C9.1007 14.8426 9.12224 14.9657 9.12224 15.0923C9.12224 15.3527 9.03249 15.5673 8.85299 15.7361C8.67349 15.912 8.45091 16 8.18525 16C8.056 16 7.93394 15.9754 7.81906 15.9261C7.697 15.8769 7.57853 15.796 7.46365 15.6834L0.323101 8.70712C0.1077 8.50308 0 8.26737 0 8C0 7.73263 0.1077 7.49692 0.323101 7.29288L7.48519 0.295514C7.69341 0.0985041 7.92676 0 8.18525 0ZM19.0522 7.06069C19.3323 7.06069 19.562 7.14864 19.7415 7.32454C19.9138 7.50044 20 7.72559 20 8C20 8.27441 19.9138 8.49956 19.7415 8.67546C19.562 8.85136 19.3323 8.93931 19.0522 8.93931L5.42811 8.93931L1.96015 8.72823C1.73757 8.71416 1.55807 8.6438 1.42165 8.51715C1.28523 8.3905 1.21702 8.21812 1.21702 8C1.21702 7.78892 1.28523 7.62005 1.42165 7.4934C1.55807 7.36675 1.73757 7.29288 1.96015 7.27177L5.42811 7.06069L19.0522 7.06069Z" fill="#1A2A49"/>
              </svg>
            </button>
          </div>
      <div class="lp-product-info__trust">
        <div class="lp-trustpilot-badge">
          <div class="trustpilot-widget" data-locale="en-US" data-template-id="5419b732fbfb950b10de65e5" data-businessunit-id="6983ad4bc5b7f0ff5cd3dc11" data-style-height="24px" data-style-width="100%" data-token="8793ee1f-5401-4ce5-9b04-2cbb5c2aac35">
            <a href="https://www.trustpilot.com/review/www.serlinolab.com" target="_blank" rel="noopener">Trustpilot</a>
          </div>
        </div>
      </div>

      <div class="lp-product-title">{% if section.settings.title_override != blank %}{{ section.settings.title_override }}{% else %}<p>{{ product.title }}</p>{% endif %}</div>
      <div class="lp-product-description">{% if section.settings.description_override != blank %}{{ section.settings.description_override }}{% else %}{{ product.description }}{% endif %}</div>

      <div class="lp-benefits-grid">
        {% for block in section.blocks %}
          {% if block.type == 'benefit' %}
            <div class="lp-benefit-card">
              <div class="lp-benefit-icon">
                {% if block.settings.icon_svg != blank %}
                  {{ block.settings.icon_svg }}
                {% endif %}
              </div>
              <p class="lp-benefit-text">{{ block.settings.text }}</p>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% comment %} Quantity / Bundle Selector {% endcomment %}
      <div class="lp-variant-picker">
        <h3 class="lp-variant-picker__title">Select Quantity</h3>
        {%- assign first_bundle_found = false -%}
        <div class="lp-variant-picker__options">
          {% for block in section.blocks %}
            {% if block.type == 'bundle' %}
              {%- assign bundle_qty = block.settings.quantity | default: 1 -%}
              {%- assign bundle_variant = product.selected_or_first_available_variant -%}
              {%- assign base_price = bundle_variant.price -%}
              {%- assign disc_pct = block.settings.discount_percentage | default: '0' | plus: 0 -%}
              {%- if disc_pct > 0 -%}
                {%- assign discount_amount = base_price | times: disc_pct | divided_by: 100.0 -%}
                {%- assign discounted_price = base_price | minus: discount_amount -%}
              {%- else -%}
                {%- assign discounted_price = base_price -%}
              {%- endif -%}
              {%- assign gift_ids = '' -%}
              {%- if block.settings.enable_free_gifts -%}
                {%- if block.settings.gift_1_product != blank -%}
                  {%- assign g1_variant = block.settings.gift_1_product.selected_or_first_available_variant -%}
                  {%- if g1_variant -%}{%- assign gift_ids = gift_ids | append: g1_variant.id -%}{%- endif -%}
                {%- endif -%}
                {%- if block.settings.gift_2_product != blank -%}
                  {%- assign g2_variant = block.settings.gift_2_product.selected_or_first_available_variant -%}
                  {%- if g2_variant -%}{%- if gift_ids != '' -%}{%- assign gift_ids = gift_ids | append: ',' -%}{%- endif -%}{%- assign gift_ids = gift_ids | append: g2_variant.id -%}{%- endif -%}
                {%- endif -%}
                {%- if block.settings.gift_3_product != blank -%}
                  {%- assign g3_variant = block.settings.gift_3_product.selected_or_first_available_variant -%}
                  {%- if g3_variant -%}{%- if gift_ids != '' -%}{%- assign gift_ids = gift_ids | append: ',' -%}{%- endif -%}{%- assign gift_ids = gift_ids | append: g3_variant.id -%}{%- endif -%}
                {%- endif -%}
              {%- endif -%}
              <div class="lp-bundle-item" {{ block.shopify_attributes }}>
                <input
                  type="radio"
                  name="bundle-selection"
                  id="bundle-{{ block.id }}"
                  class="lp-bundle-radio"
                  data-variant-id="{{ bundle_variant.id }}"
                  data-quantity="{{ bundle_qty }}"
                  data-discounted-price="{{ discounted_price }}"
                  data-original-price="{{ base_price }}"
                  data-discount="{{ disc_pct }}"
                  data-gift-variant-ids="{{ gift_ids }}"
                  data-shipping-info="{{ block.settings.shipping_info | escape }}"
                  {% unless first_bundle_found %}checked{% endunless %}
                >
                {%- assign first_bundle_found = true -%}
                <label for="bundle-{{ block.id }}" class="lp-bundle-card">
                  {% if block.settings.badge_text != blank %}
                    <span class="lp-bundle-badge lp-bundle-badge--{{ block.settings.badge_type }}">{{ block.settings.badge_text }}</span>
                  {% endif %}
                  <div class="lp-bundle-header">
                    <div class="lp-bundle-title-group">
                      <span class="lp-bundle-selector-ui"></span>
                      <span class="lp-bundle-title">{{ block.settings.title | default: bundle_variant.title }}</span>
                      {% if block.settings.shipping_info != blank %}
                        <span class="lp-bundle-shipping-tag">{{ block.settings.shipping_info }}</span>
                      {% endif %}
                    </div>
                    <div class="lp-bundle-pricing">
                      {% if disc_pct > 0 %}
                        <span class="lp-bundle-price-old">{{ base_price | divided_by: 100 | prepend: '$' }}</span>
                      {% endif %}
                      <span class="lp-bundle-price-new">{{ discounted_price | money }}<small style="font-size:12px">/ea</small></span>
                    </div>
                  </div>
                  
                  {% if block.settings.enable_free_gifts %}
                    {%- assign any_gift = false -%}
                    {%- if block.settings.gift_1_name != blank %}{% assign any_gift = true %}{% endif -%}
                    {%- if block.settings.gift_2_name != blank %}{% assign any_gift = true %}{% endif -%}
                    {%- if block.settings.gift_3_name != blank %}{% assign any_gift = true %}{% endif -%}
                    {% if any_gift %}
                      <div class="lp-bundle-gifts">
                      
                        <div class="lp-gifts-header">Free gifts included{% if block.settings.gift_value != blank %} (worth {{ block.settings.gift_value }}){% endif %}:</div>
                        <div class="lp-gift-items">
                          {% if block.settings.gift_1_name != blank %}
                            <div class="lp-gift-row">
                              {% if block.settings.gift_1_image != blank %}
                                <img class="lp-gift-row__img" src="{{ block.settings.gift_1_image | image_url: width: 80 }}" alt="{{ block.settings.gift_1_name | escape }}" width="40" height="40" loading="lazy">
                              {% endif %}
                              <div class="lp-gift-row__text">
                                <span class="lp-gift-row__primary">{{ block.settings.gift_1_name }}</span>
                                {% if block.settings.gift_1_value != blank %}
                                  <span class="lp-gift-row__secondary">({{ block.settings.gift_1_value }})</span>
                                {% endif %}
                              </div>
                              {% if block.settings.gift_1_info != blank %}
                                <span class="lp-gift-row__info-trigger" tabindex="0" aria-label="More info">
                                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7.5" stroke="currentColor"/><path d="M8 7V11M8 5.5V5" stroke="currentColor" stroke-linecap="round"/></svg>
                                  <span class="lp-gift-row__info-tooltip">{{ block.settings.gift_1_info }}</span>
                                </span>
                              {% endif %}
                            </div>
                          {% endif %}
                          {% if block.settings.gift_2_name != blank %}
                            <div class="lp-gift-row">
                              {% if block.settings.gift_2_image != blank %}
                                <img class="lp-gift-row__img" src="{{ block.settings.gift_2_image | image_url: width: 80 }}" alt="{{ block.settings.gift_2_name | escape }}" width="40" height="40" loading="lazy">
                              {% endif %}
                              <div class="lp-gift-row__text">
                                <span class="lp-gift-row__primary">{{ block.settings.gift_2_name }}</span>
                                {% if block.settings.gift_2_value != blank %}
                                  <span class="lp-gift-row__secondary">({{ block.settings.gift_2_value }})</span>
                                {% endif %}
                              </div>
                              {% if block.settings.gift_2_info != blank %}
                                <span class="lp-gift-row__info-trigger" tabindex="0" aria-label="More info">
                                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="7.5" stroke="currentColor"/><path d="M8 7V11M8 5.5V5" stroke="currentColor" stroke-linecap="round"/></svg>
                                  <span class="lp-gift-row__info-tooltip">{{ block.settings.gift_2_info }}</span>
                                </span>
                              {% endif %}
                            </div>
                          {% endif %}
                          {% if block.settings.gift_3_name != blank %}
                            <div class="lp-gift-row">
                              {% if block.settings.gift_3_image != blank %}
                                <img class="lp-gift-row__img" src="{{ block.settings.gift_3_image | image_url: width: 80 }}" alt="{{ block.settings.gift_3_name | escape }}" width="40" height="40" loading="lazy">
                              {% endif %}
                              <div class="lp-gift-row__text">
                                <span class="lp-gift-row__primary">{{ block.settings.gift_3_name }}</span>
                                {% if block.settings.gift_3_value != blank %}
                                  <span class="lp-gift-row__secondary">({{ block.settings.gift_3_value }})</span>
                                {% endif %}
                              </div>
                              {% if block.settings.gift_3_info != blank %}
