<div class="as-seen-on-section">
  <p class="heading">{{ section.settings.heading }}</p>

  <div class="logos">
    {% for block in section.blocks %}
      <div class="logo-item">
        <div class="logo-desktop">
          {% if block.settings.svg_desktop != blank %}
            {{
              block.settings.svg_desktop 
              | image_url: width: section.settings.image_width
              | image_tag: 
                alt: block.settings.image_alt | default: section.settings.heading,
                loading: 'lazy'
            }}
          {% endif %}
        </div>

        <div class="logo-mobile">
          {% if block.settings.svg_mobile != blank %}
            {{
              block.settings.svg_mobile 
              | image_url: width: section.settings.image_width
              | image_tag: 
                alt: block.settings.image_alt | default: section.settings.heading,
                loading: 'lazy'
            }}
          {% else %}
            {{
              block.settings.svg_desktop 
              | image_url: width: section.settings.image_width
              | image_tag: 
                alt: block.settings.image_alt | default: section.settings.heading,
                loading: 'lazy'
            }}
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>

<style>
.as-seen-on-section {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 17px;
  background: #F4F5F4;
  padding: 64px 200px;
}

.as-seen-on-section p {
  margin: 0;
  font-size: 22px;
  font-style: normal;
  font-weight: 500;
  line-height: 39px;
  letter-spacing: -1px;
  color: #17162E;
}

/* Logos layout */
.logos {
  display: flex;
  gap: 91px;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
}

.logo-item {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Default: Desktop visible, mobile hidden */
.logo-mobile {
  display: none;
}

.logo-desktop img,
.logo-mobile img {
  max-height: 30px;
  width: auto;
  display: block;
}

/* Tablet view */
@media screen and (min-width: 749px) and (max-width: 1300px) {
  .logos {
    gap: 20px;
  }
  
  .as-seen-on-section {
    padding: 48px 100px;
  }
  
  .as-seen-on-section p {
    font-size: 16px;
  }
}

/* Mobile view */
@media screen and (max-width: 749px) {
  .logo-desktop {
    display: none;
  }

  .logo-mobile {
    display: block;
  }

  .logos {
    gap: 20px;
    justify-content: flex-start;
  }
  
  .as-seen-on-section {
    align-items: flex-start;
    padding: 0px 20px 36px;
  }
  
  .as-seen-on-section p {
    font-size: 16px;
  }
}
</style>

{% schema %}
{
  "name": "As Seen On",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "As seen on"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Logo Width",
      "min": 50,
      "max": 300,
      "step": 10,
      "default": 150,
      "unit": "px",
      "info": "Maximum width for logos"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "svg_desktop",
          "label": "Logo for Desktop"
        },
        {
          "type": "image_picker",
          "id": "svg_mobile",
          "label": "Logo for Mobile"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Alt Text",
          "default": "Logo",
          "info": "Accessibility text for the logo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "As Seen On"
    }
  ]
}
{% endschema %}