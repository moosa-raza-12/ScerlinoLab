</script></div></div><div data-rid="9cdd3a1d-1c54-4a43-8a20-b52889a1cb51" class="r-19axv35 alchemy-rte"><span style="width:100%"><p>PREFER IT OVER THEIR PREVIOUS SKINCARE</p></span></div></div><div data-rid="f2218c45-eb4e-4f8e-a6f8-8aa87f1c5ea0" class="r-1kycue7"><div data-rid="398a4b0a-11ff-4b34-94f4-0f6561cdc3cf" class="r-wt008y"><div data-rid="9e6adda1-7a58-4a6e-a134-b2e3f3cd7e57" class="r-jaid6p"><svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 16 16" role="presentation" style="width:var(--rsw, 100%);height:auto;max-height:100%" class="r-g96giq" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg"><path d="M16 8A8 8 0 1 0 0 8a8 8 0 0 0 16 0m-7.5 3.5a.5.5 0 0 1-1 0V5.707L5.354 7.854a.5.5 0 1 1-.708-.708l3-3a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1-.708.708L8.5 5.707z"></path></svg></div><div data-rid="c074fe2c-4834-4f8e-9cd2-6abc6731b108" class="r-144urc7"><div class="smooth-counter" data-target="91">0%</div>

<style>
  .smooth-counter {
    font-family: "ABC Repro Medium", sans-serif;
    font-weight: 500;
    font-size: 48px;
    line-height: 1;
    color: #ffffff; /* bianco */
  }

  @media (max-width: 768px) {
    .smooth-counter {
      font-size: 38px;
    }
  }
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const counter = document.querySelector(".smooth-counter");

  const animate = () => {
    const target = +counter.getAttribute("data-target");
    const duration = 1800; // ms
    const start = 0;
    const startTime = performance.now();

    const easeOutCubic = (t) => 1 - Math.pow(1 - t, 3);

    const update = (currentTime) => {
      const elapsed = currentTime - startTime;
      const progress = Math.min(elapsed / duration, 1);
      const eased = easeOutCubic(progress);

      const value = Math.floor(start + eased * (target - start));
      counter.textContent = value + "%";

      if (progress < 1) {
        requestAnimationFrame(update);
      }
    };

    requestAnimationFrame(update);
  };

  const observer = new IntersectionObserver(
    (entries, obs) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          animate();
          obs.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.4 }
  );

  observer.observe(counter);
});
</script></div></div><div data-rid="7363f7d3-74ee-434f-b722-a007dd12dd0d" class="r-u967v alchemy-rte"><span style="width:100%"><p>WOULD RECOMMEND TO A FRIEND</p></span></div></div></div></div><div data-rid="30073eb1-879f-46aa-a05c-da92bfed029e" class="r-1xrtdfx"><div data-rid="51d8b0e5-5319-4692-bf6d-6ebb8c1fc4ae" class="r-1dolagq alchemy-rte"><span style="width:100%"><p>Recommended by Italian Pharmacists</p></span></div><div data-rid="4f33d9fc-4561-4f1e-921f-5b0739313723" class="r-1d3y5mu alchemy-rte"><span style="width:100%"><p>Recommended<br>by Italian Pharmacists</p></span></div><div data-rid="dd2461ee-66b4-4b52-84e4-fd881cf48f3c" class="r-13ct1ph" id="replo-carousel::Rij2:" role="region" aria-label="Carousel" data-replo-carousel="true"><button type="button" data-replo-component-root="carousel" data-replo-part="nav-button" data-direction="previous" aria-label="Previous slide" data-rid="45258a4a-2c76-43af-91a1-6accf1d47b78" class="r-vn0os5 r-kfrbt0"><div data-rid="a605d3fa-3808-43c7-ba98-3f3b8979bca3" class="r-1jp883b"><svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 16 16" role="presentation" style="width:var(--rsw, 100%);height:auto;max-height:100%" class="r-62vke6" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0"></path></svg></div></button><div data-rid="df225c04-af51-4a65-b5b6-13493069c472" class="r-t6oifw"><div data-replo-component-root="carousel" data-replo-part="slides" data-replo-root-id="replo-carousel:Rlij2:" data-orientation="horizontal" data-active-slide-position="start" role="region" aria-label="Carousel slides" dir="ltr" style="padding-left:0;padding-right:0;width:100%;height:100%;overflow:visible;position:relative" id="replo-carousel:Rlij2::track"><div data-replo-component-root="carousel" data-replo-part="slide-track" data-replo-root-id="replo-carousel:Rlij2:" data