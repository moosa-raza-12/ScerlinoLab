{{ 'kv-lp-new-design-product-results-others-notice.css' | asset_url | stylesheet_tag }}

<section class="lp-results-notice" id="lp-section-{{ section.id }}">
  <div class="lp-results-notice__container" id="lp-results-notice-container">
    {% if section.settings.title != blank %}
      <header class="lp-results-notice__header">
        <h2 class="lp-results-notice__title">{{ section.settings.title }}</h2>
      </header>
    {% endif %}

    <div class="lp-results-notice__list-wrapper">
      <div class="lp-results-notice__list" id="lp-results-notice-list-{{ section.id }}">
        {% for block in section.blocks %}
          <div class="lp-results-notice__card" {{ block.shopify_attributes }}>
            <div class="lp-results-notice__media">
              <div class="lp-results-notice__images-grid">
                <div class="lp-results-notice__img-box">
                  {% if block.settings.image_before != blank %}
                    {{ block.settings.image_before | image_url: width: 400 | image_tag: loading: 'lazy', class: 'lp-results-notice__img' }}
                  {% else %}
                    {{ 'image' | placeholder_svg_tag: 'lp-results-notice__placeholder' }}
                  {% endif %}
                  <span class="lp-results-notice__label">{{ block.settings.label_before }}</span>
                </div>
                <div class="lp-results-notice__img-box">
                  {% if block.settings.image_after != blank %}
                    {{ block.settings.image_after | image_url: width: 400 | image_tag: loading: 'lazy', class: 'lp-results-notice__img' }}
                  {% else %}
                    {{ 'image' | placeholder_svg_tag: 'lp-results-notice__placeholder' }}
                  {% endif %}
                  <span class="lp-results-notice__label">{{ block.settings.label_after }}</span>
                </div>
              </div>
            </div>

            <div class="lp-results-notice__info">
              <h3 class="lp-results-notice__reviewer-name">{{ block.settings.reviewer_name }}</h3>
              <p class="lp-results-notice__reviewer-subtitle">{{ block.settings.reviewer_subtitle }}</p>
              <p class="lp-results-notice__testimonial">
                {{ block.settings.testimonial }}
              </p>
              <div class="lp-results-notice__tags">
                {% if block.settings.tag_1 != blank %}
                  <span class="lp-results-notice__tag">{{ block.settings.tag_1 }}</span>
                {% endif %}
                {% if block.settings.tag_2 != blank %}
                  <span class="lp-results-notice__tag">{{ block.settings.tag_2 }}</span>
                {% endif %}
                 {% if block.settings.tag_3 != blank %}
                  <span class="lp-results-notice__tag">{{ block.settings.tag_3 }}</span>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="lp-results-notice__nav">
      <button class="lp-results-notice__arrow lp-results-notice__arrow--prev" data-nav="prev" aria-label="Previous">
        <svg width="20" height="16" viewBox="0 0 20 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M8 1L1 8L8 15M1 8H19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="lp-results-notice__dots" id="lp-results-notice-dots-{{ section.id }}">
        {% for block in section.blocks %}
          <span class="lp-results-notice__dot{% if forloop.first %} is-active{% endif %}" data-dot="{{ forloop.index0 }}"></span>
        {% endfor %}
      </div>
      <button class="lp-results-notice__arrow lp-results-notice__arrow--next" data-nav="next" aria-label="Next">
        <svg width="20" height="16" viewBox="0 0 20 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 1L19 8L12 15M19 8H1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>

<script>
(function() {
  var section = document.querySelector('#lp-section-{{ section.id }}');
  if (!section) return;

  var listWrapper = section.querySelector('.lp-results-notice__list-wrapper');
  var list = section.querySelector('.lp-results-notice__list');
  var cards = section.querySelectorAll('.lp-results-notice__card');
  var dotsContainer = section.querySelector('#lp-results-notice-dots-{{ section.id }}');
  var prevBtn = section.querySelector('[data-nav="prev"]');
  var nextBtn = section.querySelector('[data-nav="next"]');
  var totalCards = cards.length;

  if (!listWrapper || totalCards === 0) return;

  var currentPage = 0;
  var mode = '';

  function isDesktop() {
    return window.innerWidth >= 1024;
  }

  function getPerPage() {
    return isDesktop() ? 3 : 1;
  }

  function getTotalPages() {
    return isDesktop() ? Math.ceil(totalCards / getPerPage()) : totalCards;
  }

  function getGap() {
    if (!list) return 20;
    return parseFloat(getComputedStyle(list).gap) || 20;
  }

  /* ── Desktop: transform-based page slider ── */

  function sizeCardsDesktop() {
    var gap = getGap();
    var containerWidth = listWrapper.offsetWidth;
    var cardW = (containerWidth - gap * 2) / 3;
    cards.forEach(function(card) { card.style.width = cardW + 'px'; });
  }

  function slideToPage(page, smooth) {
    var gap = getGap();
    var containerWidth = listWrapper.offsetWidth;
    var pageWidth = containerWidth + gap;
    var cardW = (containerWidth - gap * 2) / 3;
    var totalWidth = totalCards * (cardW + gap) - gap;
    var maxOffset = totalWidth - containerWidth;
    var offset = Math.min(page * pageWidth, maxOffset);
    if (offset < 0) offset = 0;
    list.style.transition = smooth ? 'transform 0.45s ease' : 'none';
    list.style.transform = 'translateX(-' + offset + 'px)';
  }

  /* ── Mobile: scroll-based card slider ── */

  function getCardWidth() {
    if (cards.length === 0) return 0;
    return cards[0].offsetWidth + getGap();
  }

  function getMobileIndex() {
    var cardWidth = getCardWidth();
    if (cardWidth === 0) return 0;
    var idx = Math.round(listWrapper.scrollLeft / cardWidth);
    return Math.min(Math.max(0, idx), totalCards - 1);
  }

  function scrollToCard(index, smooth) {
    if (index < 0) index = 0;
    if (index >= totalCards) index = totalCards - 1;
    var cardWidth = getCardWidth();
    if (cardWidth === 0) return;
    listWrapper.scrollTo({
      left: index * cardWidth,
      behavior: smooth ? 'smooth' : 'auto'
    });
  }

  /* ── Shared: dots + buttons ── */

  function buildDots() {
    var total = isDesktop() ? getTotalPages() : totalCards;
    dotsContainer.innerHTML = '';
    for (var i = 0; i < total; i++) {
      var dot = document.createElement('span');
      dot.className = 'lp-results-notice__dot' + (i === 0 ? ' is-active' : '');
      dot.setAttribute('data-dot', i);
      dot.addEventListener('click', (function(idx) {
        return function() { goTo(idx, true); };
      })(i));
      dotsContainer.appendChild(dot);
    }
  }

  function updateDots() {
    var idx = isDesktop() ? currentPage : getMobileIndex();
    var dots = dotsContainer.querySelectorAll('[data-dot]');
    dots.forEach(function(dot, i) {
      dot.classList.toggle('is-active', i === idx);
    });
  }

  function updateButtons() {
    var idx = isDesktop() ? currentPage : getMobileIndex();
    var max = isDesktop() ? getTotalPages() - 1 : totalCards - 1;

    if (idx <= 0) {
      prevBtn.classList.remove('is-active');
    } else {
      prevBtn.classList.add('is-active');
    }
    if (idx >= max) {
      nextBtn.classList.remove('is-active');
    } else {
      nextBtn.classList.add('is-active');
    }
  }

  function goTo(idx, smooth) {
    if (isDesktop()) {
      var maxPage = getTotalPages() - 1;
      if (idx < 0) idx = 0;
      if (idx > maxPage) idx = maxPage;
      currentPage = idx;
      slideToPage(currentPage, smooth);
    } else {
      scrollToCard(idx, smooth);
    }
    updateDots();
    updateButtons();
  }

  /* ── Events ── */

  prevBtn.addEventListener('click', function() {
    var idx = isDesktop() ? currentPage : getMobileIndex();
    if (idx > 0) goTo(idx - 1, true);
  });

  nextBtn.addEventListener('click', function() {
    var idx = isDesktop() ? currentPage : getMobileIndex();
    var max = isDesktop() ? getTotalPages() - 1 : totalCards - 1;
    if (idx < max) goTo(idx + 1, true);
  });

  var scrollTimeout;
  listWrapper.addEventListener('scroll', function() {
    if (isDesktop()) return;
    clearTimeout(scrollTimeout);
    scrollTimeout = setTimeout(function() {
      updateDots();
      updateButtons();
    }, 50);
  });

  var touchStartX = 0;
  listWrapper.addEventListener('touchstart', function(e) {
    touchStartX = e.changedTouches[0].screenX;
  });
  listWrapper.addEventListener('touchend', function(e) {
    var touchEndX = e.changedTouches[0].screenX;
    var threshold = 50;
    var idx = isDesktop() ? currentPage : getMobileIndex();
    var max = isDesktop() ? getTotalPages() - 1 : totalCards - 1;

    if (touchEndX < touchStartX - threshold && idx < max) {
      goTo(idx + 1, true);
    } else if (touchEndX > touchStartX + threshold && idx > 0) {
      goTo(idx - 1, true);
    }
  });

  document.addEventListener('keydown', function(e) {
    var rect = section.getBoundingClientRect();
    if (rect.top >= window.innerHeight || rect.bottom <= 0) return;

    var idx = isDesktop() ? currentPage : getMobileIndex();
    var max = isDesktop() ? getTotalPages() - 1 : totalCards - 1;

    if (e.key === 'ArrowLeft' && idx > 0) {
      goTo(idx - 1, true);
      e.preventDefault();
    } else if (e.key === 'ArrowRight' && idx < max) {
      goTo(idx + 1, true);
      e.preventDefault();
    }
  });

  /* ── Setup / Resize ── */

  function setup() {
    var newMode = isDesktop() ? 'desktop' : 'mobile';

    if (newMode === 'desktop') {
      listWrapper.style.overflow = 'hidden';
      list.style.width = 'max-content';
      sizeCardsDesktop();
      slideToPage(currentPage, false);
    } else {
      listWrapper.style.overflow = '';
      list.style.transform = '';
      list.style.transition = '';
      list.style.width = '';
      cards.forEach(function(c) { c.style.width = ''; });
    }

    if (newMode !== mode) {
      mode = newMode;
      currentPage = 0;
      buildDots();
      if (newMode === 'desktop') {
        slideToPage(0, false);
      } else {
        scrollToCard(0, false);
      }
    }

    updateButtons();
    updateDots();
  }

  var resizeTimer;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(setup, 200);
  });

  setup();
})();
</script>
</section>

{% schema %}
{
  "name": "Results Notice",
  "settings": [
    {
      "type": "textarea",
      "id": "title",
      "label": "Section Title",
      "default": "Results other will\nnotice."
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_before",
          "label": "Image Before"
        },
        {
          "type": "image_picker",
          "id": "image_after",
          "label": "Image After"
        },
        {
          "type": "text",
          "id": "label_before",
          "label": "Label Before",
          "default": "Before"
        },
        {
          "type": "text",
          "id": "label_after",
          "label": "Label After",
          "default": "Month 5"
        },
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "Reviewer Name",
          "default": "Jason"
        },
        {
          "type": "text",
          "id": "reviewer_subtitle",
          "label": "Reviewer Subtitle",
          "default": "Before vs. 5 months using SerlinoLab"
        },
        {
          "type": "textarea",
          "id": "testimonial",
          "label": "Testimonial",
          "default": "After a few weeks my skin felt smoother and more firm. By week 8, the lines looked softer and my face looked noticeably more refreshed - without any greasy feel."
        },
        {
          "type": "text",
          "id": "tag_1",
          "label": "Tag 1",
          "default": "✨ Smoother texture"
        },
        {
          "type": "text",
          "id": "tag_2",
          "label": "Tag 2",
          "default": "💪 Firmer feel"
        },
        {
          "type": "text",
          "id": "tag_3",
          "label": "Tag 3",
          "default": "💪 Firmer feel"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Results Notice",
      "blocks": [
        {
          "type": "review"
        },
        {
          "type": "review"
        },
        {
          "type": "review"
        }
      ]
    }
  ]
}
{% endschema %}
