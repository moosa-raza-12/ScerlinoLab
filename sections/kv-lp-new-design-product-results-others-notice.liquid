{{ 'kv-lp-new-design-product-results-others-notice.css' | asset_url | stylesheet_tag }}

<section class="lp-results-notice" id="lp-section-{{ section.id }}">
  <div class="lp-results-notice__container" id="lp-results-notice-container">
    {% if section.settings.title != blank %}
      <header class="lp-results-notice__header">
        <h2 class="lp-results-notice__title">{{ section.settings.title }}</h2>
      </header>
    {% endif %}

    <div class="lp-results-notice__list-wrapper">
      <div class="lp-results-notice__list" id="lp-results-notice-list-{{ section.id }}">
        {% for block in section.blocks %}
          <div class="lp-results-notice__card" {{ block.shopify_attributes }}>
            <div class="lp-results-notice__media">
              <div class="lp-results-notice__images-grid">
                <div class="lp-results-notice__img-box">
                  {% if block.settings.image_before != blank %}
                    {{ block.settings.image_before | image_url: width: 400 | image_tag: loading: 'lazy', class: 'lp-results-notice__img' }}
                  {% else %}
                    {{ 'image' | placeholder_svg_tag: 'lp-results-notice__placeholder' }}
                  {% endif %}
                  <span class="lp-results-notice__label">{{ block.settings.label_before }}</span>
                </div>
                <div class="lp-results-notice__img-box">
                  {% if block.settings.image_after != blank %}
                    {{ block.settings.image_after | image_url: width: 400 | image_tag: loading: 'lazy', class: 'lp-results-notice__img' }}
                  {% else %}
                    {{ 'image' | placeholder_svg_tag: 'lp-results-notice__placeholder' }}
                  {% endif %}
                  <span class="lp-results-notice__label">{{ block.settings.label_after }}</span>
                </div>
              </div>
            </div>

            <div class="lp-results-notice__info">
              <h3 class="lp-results-notice__reviewer-name">{{ block.settings.reviewer_name }}</h3>
              <p class="lp-results-notice__reviewer-subtitle">{{ block.settings.reviewer_subtitle }}</p>
              <p class="lp-results-notice__testimonial">
                {{ block.settings.testimonial }}
              </p>
              <div class="lp-results-notice__tags">
                {% if block.settings.tag_1 != blank %}
                  <span class="lp-results-notice__tag">{{ block.settings.tag_1 }}</span>
                {% endif %}
                {% if block.settings.tag_2 != blank %}
                  <span class="lp-results-notice__tag">{{ block.settings.tag_2 }}</span>
                {% endif %}
                 {% if block.settings.tag_3 != blank %}
                  <span class="lp-results-notice__tag">{{ block.settings.tag_3 }}</span>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
    <div class="lp-results__nav">
      <button class="lp-how-to-use__arrow lp-how-to-use__arrow--prev" data-nav="prev" aria-label="Previous step">
        <svg width="20" height="16" viewBox="0 0 20 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M8 1L1 8L8 15M1 8H19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="lp-how-to-use__dots">
        {% for block in section.blocks %}
          <span class="lp-how-to-use__dot{% if forloop.first %} is-active{% endif %}" data-dot="{{ forloop.index0 }}"></span>
        {% endfor %}
      </div>
      <button class="lp-how-to-use__arrow lp-how-to-use__arrow--next" data-nav="next" aria-label="Next step">
        <svg width="20" height="16" viewBox="0 0 20 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 1L19 8L12 15M19 8H1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
  
<script>
(function() {
  const section = document.querySelector('#lp-section-{{ section.id }}');
  if (!section) return;

  const list = document.getElementById('lp-results-notice-list-{{ section.id }}');
  const prevBtn = section.querySelector('[data-nav="prev"]');
  const nextBtn = section.querySelector('[data-nav="next"]');
  const dots = section.querySelectorAll('.lp-how-to-use__dot');
  const wrapper = section.querySelector('.lp-results-notice__list-wrapper');
  
  if (!list || !prevBtn || !nextBtn || !dots.length) return;

  let currentIndex = 0;
  let isTransitioning = false;
  const originalCards = Array.from(list.querySelectorAll('.lp-results-notice__card'));
  const totalCards = originalCards.length;
  
  if (totalCards === 0) return;
  
  // Clone cards for infinite effect
  function setupInfiniteCarousel() {
    // Clear the list
    list.innerHTML = '';
    
    // Clone all cards and add clones at beginning and end
    const clonesBefore = [];
    const clonesAfter = [];
    
    // Create clones
    originalCards.forEach(card => {
      clonesBefore.push(card.cloneNode(true));
      clonesAfter.push(card.cloneNode(true));
    });
    
    // Add clones to the list
    clonesBefore.forEach(clone => list.appendChild(clone));
    originalCards.forEach(card => list.appendChild(card));
    clonesAfter.forEach(clone => list.appendChild(clone));
    
    return {
      clonesBeforeCount: clonesBefore.length,
      clonesAfterCount: clonesAfter.length,
      allCards: Array.from(list.querySelectorAll('.lp-results-notice__card'))
    };
  }
  
  const { clonesBeforeCount, clonesAfterCount, allCards } = setupInfiniteCarousel();
  const totalAllCards = allCards.length;
  const originalStartIndex = clonesBeforeCount;
  const originalEndIndex = clonesBeforeCount + totalCards - 1;
  
  // Get the container width and card width
  let cardWidth = 0;
  let gap = 0;
  let containerWidth = 0;
  
  function getDimensions() {
    if (allCards.length === 0) return;
    const card = allCards[0];
    const style = window.getComputedStyle(list);
    gap = parseFloat(style.gap) || 0;
    cardWidth = card.offsetWidth;
    containerWidth = wrapper.offsetWidth;
  }
  
  // Function to update button states
  function updateButtonStates() {
    // Remove active class from both buttons
    prevBtn.classList.remove('is-active');
    nextBtn.classList.remove('is-active');
    
    // Check if there are cards to scroll left
    const canScrollLeft = currentIndex > originalStartIndex;
    // Check if there are cards to scroll right
    const canScrollRight = currentIndex < originalEndIndex;
    
    // Add active class if button is clickable
    if (canScrollLeft) {
      prevBtn.classList.add('is-active');
    }
    if (canScrollRight) {
      nextBtn.classList.add('is-active');
    }
  }
  
  // Function to update carousel position
  function updateCarousel(index, smooth = true) {
    if (isTransitioning) return;
    
    // Calculate target scroll position
    let targetIndex = index;
    
    // Handle infinite wrapping
    if (targetIndex < 0) {
      targetIndex = originalEndIndex;
      setTimeout(() => {
        jumpToIndex(targetIndex);
      }, 300);
    } else if (targetIndex >= totalAllCards) {
      targetIndex = originalStartIndex;
      setTimeout(() => {
        jumpToIndex(targetIndex);
      }, 300);
    }
    
    // Calculate scroll position
    const scrollPosition = targetIndex * (cardWidth + gap);
    
    // Update active dot (map to original card index)
    let activeDotIndex = targetIndex - originalStartIndex;
    if (activeDotIndex < 0) activeDotIndex = totalCards + activeDotIndex;
    if (activeDotIndex >= totalCards) activeDotIndex = activeDotIndex - totalCards;
    
    dots.forEach((dot, i) => {
      if (i === activeDotIndex) {
        dot.classList.add('is-active');
      } else {
        dot.classList.remove('is-active');
      }
    });
    
    // Scroll to position
    if (smooth) {
      list.scrollTo({
        left: scrollPosition,
        behavior: 'smooth'
      });
    } else {
      list.scrollLeft = scrollPosition;
    }
    
    currentIndex = targetIndex;
    
    // Update button states after position change
    updateButtonStates();
  }
  
  function jumpToIndex(index) {
    isTransitioning = true;
    const scrollPosition = index * (cardWidth + gap);
    list.scrollLeft = scrollPosition;
    currentIndex = index;
    
    setTimeout(() => {
      isTransitioning = false;
      updateButtonStates();
    }, 50);
  }
  
  // Next button click handler
  nextBtn.addEventListener('click', () => {
    if (isTransitioning) return;
    // Check if we can scroll right before moving
    if (currentIndex < originalEndIndex) {
      updateCarousel(currentIndex + 1);
    }
  });
  
  // Previous button click handler
  prevBtn.addEventListener('click', () => {
    if (isTransitioning) return;
    // Check if we can scroll left before moving
    if (currentIndex > originalStartIndex) {
      updateCarousel(currentIndex - 1);
    }
  });
  
  // Dot click handlers
  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      if (isTransitioning) return;
      const targetCardIndex = originalStartIndex + index;
      if (targetCardIndex >= originalStartIndex && targetCardIndex <= originalEndIndex) {
        updateCarousel(targetCardIndex);
      }
    });
  });
  
  // Handle scroll end for infinite effect
  let scrollTimeout;
  list.addEventListener('scroll', () => {
    if (isTransitioning) return;
    
    clearTimeout(scrollTimeout);
    scrollTimeout = setTimeout(() => {
      const scrollPosition = list.scrollLeft;
      const cardTotalWidth = cardWidth + gap;
      let nearestIndex = Math.round(scrollPosition / cardTotalWidth);
      
      // Clamp index
      nearestIndex = Math.max(0, Math.min(nearestIndex, totalAllCards - 1));
      
      // Handle infinite wrapping
      if (nearestIndex < originalStartIndex) {
        const wrappedIndex = originalEndIndex - (originalStartIndex - nearestIndex - 1);
        updateCarousel(wrappedIndex, false);
      } else if (nearestIndex > originalEndIndex) {
        const wrappedIndex = originalStartIndex + (nearestIndex - originalEndIndex - 1);
        updateCarousel(wrappedIndex, false);
      } else if (nearestIndex !== currentIndex) {
        updateCarousel(nearestIndex, false);
      }
    }, 100);
  });
  
  // Touch swipe support
  let touchStartX = 0;
  let touchEndX = 0;
  
  if (wrapper) {
    wrapper.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    });
    
    wrapper.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      const swipeThreshold = 50;
      
      if (touchEndX < touchStartX - swipeThreshold) {
        nextBtn.click();
      } else if (touchEndX > touchStartX + swipeThreshold) {
        prevBtn.click();
      }
    });
  }
  
  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    const rect = section.getBoundingClientRect();
    const isVisible = rect.top < window.innerHeight && rect.bottom > 0;
    
    if (!isVisible) return;
    
    if (e.key === 'ArrowLeft') {
      prevBtn.click();
      e.preventDefault();
    } else if (e.key === 'ArrowRight') {
      nextBtn.click();
      e.preventDefault();
    }
  });
  
  // Initialize dimensions and position
  function initialize() {
    getDimensions();
    list.style.scrollBehavior = 'auto';
    list.scrollLeft = originalStartIndex * (cardWidth + gap);
    currentIndex = originalStartIndex;
    list.style.scrollBehavior = '';
    updateButtonStates(); // Initialize button states
  }
  
  // Recalculate on window resize
  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      getDimensions();
      jumpToIndex(currentIndex);
    }, 250);
  });
  
  // Initialize after images load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initialize);
  } else {
    initialize();
  }
})();
</script>
</section>

{% schema %}
{
  "name": "Results Notice",
  "settings": [
    {
      "type": "textarea",
      "id": "title",
      "label": "Section Title",
      "default": "Results other will\nnotice."
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_before",
          "label": "Image Before"
        },
        {
          "type": "image_picker",
          "id": "image_after",
          "label": "Image After"
        },
        {
          "type": "text",
          "id": "label_before",
          "label": "Label Before",
          "default": "Before"
        },
        {
          "type": "text",
          "id": "label_after",
          "label": "Label After",
          "default": "Month 5"
        },
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "Reviewer Name",
          "default": "Jason"
        },
        {
          "type": "text",
          "id": "reviewer_subtitle",
          "label": "Reviewer Subtitle",
          "default": "Before vs. 5 months using SerlinoLab"
        },
        {
          "type": "textarea",
          "id": "testimonial",
          "label": "Testimonial",
          "default": "“After a few weeks my skin felt smoother and more firm. By week 8, the lines looked softer and my face looked noticeably more refreshed — without any greasy feel.”"
        },
        {
          "type": "text",
          "id": "tag_1",
          "label": "Tag 1",
          "default": "✨ Smoother texture"
        },
        {
          "type": "text",
          "id": "tag_2",
          "label": "Tag 2",
          "default": "💪 Firmer feel"
        },
        {
          "type": "text",
          "id": "tag_3",
          "label": "Tag 3",
          "default": "💪 Firmer feel"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Results Notice",
      "blocks": [
        {
          "type": "review"
        },
        {
          "type": "review"
        },
        {
          "type": "review"
        }
      ]
    }
  ]
}
{% endschema %}