    "gp_section_598209469721412492": {
      "settings": {
        "checksum": "ca8e5b3b5f6ef1833f69fc248085abe6cc76447ff3006ceb76b3c8117295c7f8_1_1_1_0__1",
        "gg-lSpHSfJU_childItem_0": "<p><strong>The fragrance: </strong>light touch of lavender</p>",
        "gg-lSpHSfJU_childItem_1": "<p><strong>The consistency: </strong>light and very fresh</p>",
        "gg-lSpHSfJU_childItem_2": "<p><strong>Makes your skin feel: </strong>hydrated, soft and smooth</p>",
        "gg-lSpHSfJU_childItem_3": "<p><strong>Makes your skin look: </strong>revitalized, deflated and radiant</p>",
        "ggJuSNkLiTs_text": "Quick Absorption without Greasiness!",
        "ggL6S9FzqeB_text": "<p><strong>Tried Beef Tallow? You're Not Alone.&nbsp;</strong></p><p>&nbsp;</p><p>50% of our customers switched from tallow products. <strong>Here's the difference:&nbsp;</strong></p><p>&nbsp;</p><p>Tallow <strong>sits</strong> on your skin (greasy, smells, clogs pores).&nbsp;</p><p>&nbsp;</p><p>Omnis <strong>penetrates to rebuild collagen structure</strong> with pharmaceutical-grade precision, no barnyard smell, no pillow stains.</p>",
        "ggjX935BoQx_text": "Beef Tallow Didn't Work? Here's Why"
      },
