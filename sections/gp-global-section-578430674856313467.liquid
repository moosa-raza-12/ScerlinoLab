document.addEventListener("DOMContentLoaded", () => { 
    if (window.innerWidth < 768) { // Only run the script if screen width is less than 768px

        const currentElement = document.getElementsByClassName('gCmF-rq0T5');

        var main = currentElement[0].querySelector('.gf_main-slider').slider;
        main.moveToIdx(2, true);
        var slider = currentElement[0].querySelector('.gf_thumb-slider').slider;

        function removeActive() {
            slider.slides.forEach((slide) => {
                slide.classList.remove("gf_slide-active")
            })
        }

        function addActive(idx) {
            slider.slides[idx].classList.add("gf_slide-active")
        }  

        function addClickEvents() {
            slider.slides.forEach((slide, idx) => {
                slide.addEventListener("click", () => {
                    main.moveToIdx(idx)
                })
            })
        }

        function setHeightMainSlider() {
            var highestBox = 0;
            currentElement[0].querySelectorAll('.gf_main-slider .gem-slider-item img').forEach(function(el){
                if (el.offsetHeight > highestBox) {
                    highestBox = el.offsetHeight;
                }
            })
            currentElement[0].querySelector('.gf_main-slider .gem-slider').style.height = highestBox + 'px';
        }

        function fadeMainSlider() {
            main.options.defaultAnimation = {duration: 1};

            main.on('detailsChanged', s => {
                s.slides.forEach((element, idx) => {
                    console.log('portion', s.track.details.slides[idx].portion);
                    element.style.opacity = s.track.details.slides[idx].portion;
                })
            })
            main.options.renderMode = "custom";
        }

        setHeightMainSlider();
        fadeMainSlider();

        window.onresize = function() {
            if (window.innerWidth < 768) { // Check again on resize
                setTimeout(function(){
                    setHeightMainSlider();
                    fadeMainSlider();
                }, 100);
            }
        }

        addActive(slider.track.details.rel);
        addClickEvents();
        main.on("animationStarted", (main) => {
            removeActive();
            const next = main.animator.targetIdx || 0;
            addActive(main.track.absToRel(next));
            slider.moveToIdx(Math.min(slider.track.details.maxIdx, next));
        });
    }
});


