            "image_after": "shopify://shop_images/Rectangle_4400_1.png",
            "label_before": "Before",
            "label_after": "Month 5",
            "reviewer_name": "James, 67",
            "reviewer_subtitle": "",
            "testimonial": "\"My daughter showed me a photo from her wedding and I barely recognized myself. I looked exhausted - way older than I felt. Five months in, my coworkers genuinely asked if I'd gotten work done. I haven't. I just stopped looking like I aged overnight.\"",
            "tag_1": "Younger-looking skin",
            "tag_2": "Reduced deep lines",
            "tag_3": "Refreshed appearance"
          }
        },
        "block_0": {
          "type": "review",
          "settings": {
            "image_before": "shopify://shop_images/Rectangle_4399.png",
            "image_after": "shopify://shop_images/Rectangle_4400.png",
            "label_before": "Before",
            "label_after": "Month 4",
            "reviewer_name": "Richard, 63",
            "reviewer_subtitle": "",
            "testimonial": "\"My neck was the thing I hated most. That loose skin folding over my collar - I'd pull at it every morning. After about 6 weeks, my wife grabbed my face and said 'your neck looks different.' By month 4, I stopped wearing turtlenecks to hide it.\"",
            "tag_1": "Tighter neck skin",
            "tag_2": "Less visible sagging",
            "tag_3": "Smoother neck texture"
          }
        },
        "block_2": {
          "type": "review",
          "settings": {
            "image_before": "shopify://shop_images/Rectangle_4399_2.png",
            "image_after": "shopify://shop_images/Rectangle_4400_2.png",
            "label_before": "Before",
            "label_after": "Month 6",
            "reviewer_name": "Thomas, 59",
            "reviewer_subtitle": "",
            "testimonial": "\"I'd lost my jawline completely. Everything had kind of melted south - the jowls, the sagging along my chin. By week 8, I could actually see the edge of my jaw again. My barber noticed before I even said anything. That told me everything.\"",
            "tag_1": "Firmer jawline",
            "tag_2": "Reduced jowl sagging",
            "tag_3": "Restored facial structure"
          }
        },
        "review_WijYa3": {
          "type": "review",
          "settings": {
            "image_before": "shopify://shop_images/mike-1.png",
            "image_after": "shopify://shop_images/mike-2.png",
            "label_before": "Before",
            "label_after": "Month 4",
            "reviewer_name": "Michael, 51",
            "reviewer_subtitle": "",
            "testimonial": "\"I got back into dating after my divorce and honestly, I didn't feel great about how I looked. Three months in, a woman on our second date told me I had great skin. I'm 61. Nobody has ever said that to me in my entire life.\"",
            "tag_1": "Smoother skin texture",
            "tag_2": "Healthier complexion",
            "tag_3": "More confident appearance"
          }
        },
        "review_W8Ptka": {
          "type": "review",
          "settings": {
            "image_before": "shopify://shop_images/Rectangle_4399_4.png",
            "image_after": "shopify://shop_images/Rectangle_4400_4.png",
            "label_before": "Before",
            "label_after": "Month 5",
            "reviewer_name": "Robert, 66",
            "reviewer_subtitle": "",
            "testimonial": "\"The deep lines across my forehead and around my eyes made me look angry even when I wasn't. I'd tried drugstore creams for years - nothing. After a few weeks, the lines started softening. By month 4, people stopped asking me if something was wrong.\"",
            "tag_1": "Softer forehead lines",
            "tag_2": "Reduced crow's feet",
            "tag_3": "Smoother overall texture"
          }
        },
        "review_XkAdiT": {
          "type": "review",
          "settings": {
            "image_before": "shopify://shop_images/Rectangle_4399_5.png",
            "image_after": "shopify://shop_images/Rectangle_4400_5.png",
            "label_before": "Before",
            "label_after": "Month 3",
            "reviewer_name": "David, 58",
            "reviewer_subtitle": "",
            "testimonial": "\"I was getting 8 hours of sleep but looked like I was getting 4. The bags, the dull color, the uneven patches. My son saw me on FaceTime and said 'Dad, you look... good. What happened?' That's a first.\"",
            "tag_1": "Even skin tone",
            "tag_2": "Reduced tired appearance",
            "tag_3": "Healthier color"
          }
        }
