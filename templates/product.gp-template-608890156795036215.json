    "gp_section_608890156980437559": {
      "settings": {
        "checksum": "f2e800aac8859d985bc48967b87b03ab0d41f704e85acc3e7a03f0d3d963d965_1_1_1_0__1",
        "gg2xFSx-IzP_text": "<p><strong>Step 1:</strong> Wash your face with SerlinoLab Cleanser. Clean skin takes color better.</p><p><strong>Step 2:</strong> Put the drops in your palm. Rub evenly over face and neck in circular motions.</p><p><strong>Step 3:</strong> Wait 15–20 minutes before getting dressed.</p><p>Wash your hands right after.</p><p>For best results, exfoliate 24 hours before.</p>",
        "gg5r67GKkA8_childItem_0": "<p><span style=\"font-size:16px;\">Why this isn’t like the other self-tanners</span></p>",
