{{ 'kv-lp-new-design-product-recommended-pharmacists.css' | asset_url | stylesheet_tag }}

<section class="lp-pharmacists-section" id="lp-section-{{ section.id }}">
  <div class="lp-pharmacists-container" id="lp-pharmacists-container">
    {% if section.settings.heading != blank %}
      <header class="lp-pharmacists-header">
        <h2 class="lp-pharmacists-title">{{ section.settings.heading }}</h2>
      </header>
    {% endif %}

    <div class="lp-pharmacists-grid-wrapper">
      <div class="lp-pharmacists-grid">
        {% for block in section.blocks %}
          <div class="lp-pharmacist-card{% if block.settings.video != blank %} has-video{% endif %}" {{ block.shopify_attributes }}>
            {% if block.settings.video != blank %}
              <div class="lp-pharmacist-video-wrapper">
                {% if block.settings.image != blank %}
                  {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'lp-pharmacist-poster', alt: block.settings.name }}
                {% endif %}
                <video
                  class="lp-pharmacist-video"
                  src="{{ block.settings.video.sources[1].url | default: block.settings.video.sources[0].url }}"
                  loop
                  playsinline
                  preload="metadata"
                ></video>
                <button class="lp-pharmacist-play-btn" aria-label="Play Video">
                  <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="24" fill="rgba(0,0,0,0.45)"/><path d="M19 15L33 24L19 33V15Z" fill="white"/></svg>
                </button>
              </div>
            {% elsif block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'lp-pharmacist-image', alt: block.settings.name }}
            {% else %}
              <div class="lp-pharmacist-image-placeholder"></div>
            {% endif %}

            <div class="lp-pharmacist-info">
              <div class="lp-pharmacist-content-box">
                <p class="lp-pharmacist-quote">
                  “{{ block.settings.quote }}”
                </p>
                <div class="lp-pharmacist-profile">
                  <p class="lp-pharmacist-name">{{ block.settings.name }}</p>
                  <p class="lp-pharmacist-role">{{ block.settings.role }}</p>
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    <div class="lp-pharmacists-nav">
      <button class="lp-pharmacists-arrow lp-pharmacists-arrow--prev" data-nav="prev" aria-label="Previous">
        <svg width="20" height="16" viewBox="0 0 20 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M8 1L1 8L8 15M1 8H19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="lp-pharmacists-dots">
        {% for block in section.blocks %}
          <span class="lp-pharmacists-dot{% if forloop.first %} is-active{% endif %}" data-dot="{{ forloop.index0 }}"></span>
        {% endfor %}
      </div>
      <button class="lp-pharmacists-arrow lp-pharmacists-arrow--next" data-nav="next" aria-label="Next">
        <svg width="20" height="16" viewBox="0 0 20 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 1L19 8L12 15M19 8H1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
(function() {
  var section = document.querySelector('#lp-section-{{ section.id }}');
  if (!section) return;

  var gridWrapper = section.querySelector('.lp-pharmacists-grid-wrapper');
  var cards = section.querySelectorAll('.lp-pharmacist-card');
  var dots = section.querySelectorAll('[data-dot]');
  var prevBtn = section.querySelector('[data-nav="prev"]');
  var nextBtn = section.querySelector('[data-nav="next"]');
  var totalCards = cards.length;

  if (!gridWrapper || totalCards === 0) return;

  function getGap() {
    var grid = section.querySelector('.lp-pharmacists-grid');
    if (!grid) return 24;
    return parseFloat(getComputedStyle(grid).gap) || 24;
  }

  function getCardWidth() {
    if (cards.length === 0) return 0;
    return cards[0].offsetWidth + getGap();
  }

  function getCurrentCardIndex() {
    var cardWidth = getCardWidth();
    if (cardWidth === 0) return 0;
    var scrollPosition = gridWrapper.scrollLeft;
    var index = Math.round(scrollPosition / cardWidth);
    return Math.min(Math.max(0, index), totalCards - 1);
  }

  function updateButtonStates() {
    var currentIndex = getCurrentCardIndex();
    
    // Update prev button state
    if (currentIndex === 0) {
      prevBtn.classList.remove('is-active');
    } else {
      prevBtn.classList.add('is-active');
    }
    
    // Update next button state
    if (currentIndex === totalCards - 1) {
      nextBtn.classList.remove('is-active');
    } else {
      nextBtn.classList.add('is-active');
    }
  }

  function updateDots() {
    var currentIndex = getCurrentCardIndex();
    dots.forEach(function(dot, i) {
      dot.classList.toggle('is-active', i === currentIndex);
    });
  }

  function scrollToCard(index, smooth) {
    if (index < 0) index = 0;
    if (index >= totalCards) index = totalCards - 1;
    
    var cardWidth = getCardWidth();
    if (cardWidth === 0) return;
    
    var scrollPosition = index * cardWidth;
    
    gridWrapper.scrollTo({
      left: scrollPosition,
      behavior: smooth ? 'smooth' : 'auto'
    });
  }

  // Update states on scroll with debounce
  var scrollTimeout;
  gridWrapper.addEventListener('scroll', function() {
    clearTimeout(scrollTimeout);
    scrollTimeout = setTimeout(function() {
      updateDots();
      updateButtonStates();
    }, 50);
  });

  // Previous button click
  if (prevBtn) {
    prevBtn.addEventListener('click', function() {
      var currentIndex = getCurrentCardIndex();
      if (currentIndex > 0) {
        scrollToCard(currentIndex - 1, true);
      }
    });
  }

  // Next button click
  if (nextBtn) {
    nextBtn.addEventListener('click', function() {
      var currentIndex = getCurrentCardIndex();
      if (currentIndex < totalCards - 1) {
        scrollToCard(currentIndex + 1, true);
      }
    });
  }

  // Dot click handlers
  dots.forEach(function(dot, index) {
    dot.addEventListener('click', function() {
      scrollToCard(index, true);
    });
  });

  // Touch swipe support
  var touchStartX = 0;
  var touchEndX = 0;
  
  if (gridWrapper) {
    gridWrapper.addEventListener('touchstart', function(e) {
      touchStartX = e.changedTouches[0].screenX;
    });
    
    gridWrapper.addEventListener('touchend', function(e) {
      touchEndX = e.changedTouches[0].screenX;
      var swipeThreshold = 50;
      var currentIndex = getCurrentCardIndex();
      
      if (touchEndX < touchStartX - swipeThreshold && currentIndex < totalCards - 1) {
        scrollToCard(currentIndex + 1, true);
      } else if (touchEndX > touchStartX + swipeThreshold && currentIndex > 0) {
        scrollToCard(currentIndex - 1, true);
      }
    });
  }

  // Keyboard navigation
  document.addEventListener('keydown', function(e) {
    var rect = section.getBoundingClientRect();
    var isVisible = rect.top < window.innerHeight && rect.bottom > 0;
    
    if (!isVisible) return;
    
    var currentIndex = getCurrentCardIndex();
    
    if (e.key === 'ArrowLeft' && currentIndex > 0) {
      scrollToCard(currentIndex - 1, true);
      e.preventDefault();
    } else if (e.key === 'ArrowRight' && currentIndex < totalCards - 1) {
      scrollToCard(currentIndex + 1, true);
      e.preventDefault();
    }
  });

  // Handle window resize
  var resizeTimer;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function() {
      var currentIndex = getCurrentCardIndex();
      scrollToCard(currentIndex, false);
      updateButtonStates();
      updateDots();
    }, 250);
  });

  // Initialize
  function initialize() {
    scrollToCard(0, false);
    updateButtonStates();
    updateDots();
  }

  initialize();

  // Video handling (preserved from original)
  section.querySelectorAll('.lp-pharmacist-card.has-video').forEach(function(card) {
    var video = card.querySelector('.lp-pharmacist-video');
    var playBtn = card.querySelector('.lp-pharmacist-play-btn');
    if (!video) return;

    var isPlaying = false;
    var userPaused = false;
var btnP=document.querySelectorAll(".lp-pharmacist-play-btn")
    function play() {
      video.play().catch(function(error) {
        console.log('Play failed:', error);
        if (playBtn) btnP.style.opacity = '0';
      });
      isPlaying = true;
      card.classList.add('is-playing');

    }

    function pause() {
      video.pause();
      isPlaying = false;
      card.classList.remove('is-playing');
      if (playBtn) playBtn.style.opacity = '1'; 
    }
video.addEventListener('ended', function() {
  pause();
  video.currentTime = 0;
  if (playBtn) playBtn.style.opacity = '1';
});
    card.addEventListener('mouseleave', function() {
      if (isPlaying) {
        pause();
        video.currentTime = 0;
      }
    });

    if (playBtn) {
      playBtn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        if (isPlaying) {
          pause();
          userPaused = true;
        } else {
          play();
        }
      });
    }

    video.addEventListener('click', function(e) {
      e.preventDefault();
      if (isPlaying) {
        pause();
        userPaused = true;
      } else {
        play();
      }
    });

    video.addEventListener('ended', function() {
      pause();
      video.currentTime = 0;
    });
  });
})();
