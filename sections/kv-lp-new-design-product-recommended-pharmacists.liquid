{{ 'kv-lp-new-design-product-recommended-pharmacists.css' | asset_url | stylesheet_tag }}

<section class="lp-pharmacists-section" id="lp-section-{{ section.id }}">
  <div class="lp-pharmacists-container" id="lp-pharmacists-container">
    {% if section.settings.heading != blank %}
      <header class="lp-pharmacists-header">
        <h2 class="lp-pharmacists-title">{{ section.settings.heading }}</h2>
      </header>
    {% endif %}

    <div class="lp-pharmacists-grid-wrapper">
      <div class="lp-pharmacists-grid">
        {% for block in section.blocks %}
          <div class="lp-pharmacist-card{% if block.settings.video != blank %} has-video{% endif %}" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
            {% if block.settings.video != blank %}
              <div class="lp-pharmacist-video-wrapper">
                {% if block.settings.image != blank %}
                  {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'lp-pharmacist-poster', alt: block.settings.name }}
                {% endif %}
                <video
                  class="lp-pharmacist-video"
                  src="{{ block.settings.video.sources[1].url | default: block.settings.video.sources[0].url }}"
                  loop
                  playsinline
                  preload="metadata"
                ></video>
                <button class="lp-pharmacist-play-btn" aria-label="Play Video">
                  <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="24" fill="rgba(0,0,0,0.45)"/><path d="M19 15L33 24L19 33V15Z" fill="white"/></svg>
                </button>
              </div>
            {% elsif block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'lp-pharmacist-image', alt: block.settings.name }}
            {% else %}
              <div class="lp-pharmacist-image-placeholder"></div>
            {% endif %}

            <div class="lp-pharmacist-info">
              <div class="lp-pharmacist-content-box">
                <p class="lp-pharmacist-quote">
                  “{{ block.settings.quote }}”
                </p>
                <div class="lp-pharmacist-profile">
                  <p class="lp-pharmacist-name">{{ block.settings.name }}</p>
                  <p class="lp-pharmacist-role">{{ block.settings.role }}</p>
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
    
    <div class="lp-results__nav">
      <button class="lp-how-to-use__arrow lp-how-to-use__arrow--prev" data-nav="prev" aria-label="Previous step">
        <svg width="20" height="16" viewBox="0 0 20 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M8 1L1 8L8 15M1 8H19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="lp-how-to-use__dots">
        {% for block in section.blocks %}
          <span class="lp-how-to-use__dot{% if forloop.first %} is-active{% endif %}" data-dot="{{ forloop.index0 }}"></span>
        {% endfor %}
      </div>
      <button class="lp-how-to-use__arrow lp-how-to-use__arrow--next" data-nav="next" aria-label="Next step">
        <svg width="20" height="16" viewBox="0 0 20 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 1L19 8L12 15M19 8H1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
(function() {
  var section = document.querySelector('#lp-section-{{ section.id }}');
  if (!section) return;

  var grid = section.querySelector('.lp-pharmacists-grid');
  var cards = section.querySelectorAll('.lp-pharmacist-card');
  var prevBtn = section.querySelector('[data-nav="prev"]');
  var nextBtn = section.querySelector('[data-nav="next"]');
  var dots = section.querySelectorAll('.lp-how-to-use__dot');
  var currentIndex = 0;
  var totalCards = cards.length;
  var cardsPerView = getCardsPerView();
  var autoPlayInterval = null;
  var isHovering = false;

  // Function to determine how many cards to show based on screen width
  function getCardsPerView() {
    if (window.innerWidth >= 1024) return 3;
    if (window.innerWidth >= 768) return 2;
    return 1;
  }

  // Function to update visible cards
  function updateVisibleCards() {
    var cardsPerView = getCardsPerView();
    var maxIndex = Math.max(0, totalCards - cardsPerView);
    currentIndex = Math.min(currentIndex, maxIndex);
    
    cards.forEach(function(card, index) {
      if (index >= currentIndex && index < currentIndex + cardsPerView) {
        card.classList.add('is-visible');
        card.classList.remove('is-hidden');
      } else {
        card.classList.add('is-hidden');
        card.classList.remove('is-visible');
      }
    });
    
    // Update dots
    dots.forEach(function(dot, index) {
      if (index === currentIndex) {
        dot.classList.add('is-active');
      } else {
        dot.classList.remove('is-active');
      }
    });
    
    // Update button states
    if (prevBtn) {
      if (currentIndex === 0) {
        prevBtn.classList.add('is-disabled');
        prevBtn.disabled = true;
      } else {
        prevBtn.classList.remove('is-disabled');
        prevBtn.disabled = false;
      }
    }
    
    if (nextBtn) {
      if (currentIndex >= totalCards - cardsPerView) {
        nextBtn.classList.add('is-disabled');
        nextBtn.disabled = true;
      } else {
        nextBtn.classList.remove('is-disabled');
        nextBtn.disabled = false;
      }
    }
  }

  // Navigate to previous set
  function prevSlide() {
    var cardsPerView = getCardsPerView();
    if (currentIndex > 0) {
      currentIndex--;
      updateVisibleCards();
      resetAutoPlay();
    }
  }

  // Navigate to next set
  function nextSlide() {
    var cardsPerView = getCardsPerView();
    if (currentIndex < totalCards - cardsPerView) {
      currentIndex++;
      updateVisibleCards();
      resetAutoPlay();
    }
  }

  // Go to specific dot index
  function goToSlide(index) {
    var cardsPerView = getCardsPerView();
    var maxIndex = Math.max(0, totalCards - cardsPerView);
    if (index >= 0 && index <= maxIndex) {
      currentIndex = index;
      updateVisibleCards();
      resetAutoPlay();
    }
  }

  // Auto-play functionality
  function startAutoPlay() {
    if (autoPlayInterval) clearInterval(autoPlayInterval);
    if (!isHovering) {
      autoPlayInterval = setInterval(function() {
        var cardsPerView = getCardsPerView();
        if (currentIndex < totalCards - cardsPerView) {
          nextSlide();
        } else {
          // Loop back to start
          currentIndex = 0;
          updateVisibleCards();
        }
      }, 5000);
    }
  }

  function stopAutoPlay() {
    if (autoPlayInterval) {
      clearInterval(autoPlayInterval);
      autoPlayInterval = null;
    }
  }

  function resetAutoPlay() {
    stopAutoPlay();
    startAutoPlay();
  }

  // Event listeners for navigation
  if (prevBtn) {
    prevBtn.addEventListener('click', function(e) {
      e.preventDefault();
      prevSlide();
    });
  }

  if (nextBtn) {
    nextBtn.addEventListener('click', function(e) {
      e.preventDefault();
      nextSlide();
    });
  }

  // Dot click handlers
  dots.forEach(function(dot) {
    dot.addEventListener('click', function() {
      var index = parseInt(this.getAttribute('data-dot'));
      if (!isNaN(index)) {
        goToSlide(index);
      }
    });
  });

  // Pause auto-play on hover
  var container = section.querySelector('.lp-pharmacists-grid-wrapper');
  if (container) {
    container.addEventListener('mouseenter', function() {
      isHovering = true;
      stopAutoPlay();
    });
    
    container.addEventListener('mouseleave', function() {
      isHovering = false;
      startAutoPlay();
    });
  }

  // Handle window resize
  var resizeTimeout;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(function() {
      var newCardsPerView = getCardsPerView();
      var maxIndex = Math.max(0, totalCards - newCardsPerView);
      if (currentIndex > maxIndex) {
        currentIndex = maxIndex;
      }
      updateVisibleCards();
    }, 250);
  });

  // Video handling (preserved from original)
  section.querySelectorAll('.lp-pharmacist-card.has-video').forEach(function(card) {
    var video = card.querySelector('.lp-pharmacist-video');
    var playBtn = card.querySelector('.lp-pharmacist-play-btn');
    if (!video) return;

    var isPlaying = false;
    var userPaused = false;

    function play() {
      video.play().catch(function(error) {
        console.log('Play failed:', error);
      });
      isPlaying = true;
      card.classList.add('is-playing');
      // Pause auto-play while video is playing
      stopAutoPlay();
    }

    function pause() {
      video.pause();
      isPlaying = false;
      card.classList.remove('is-playing');
      // Resume auto-play if not hovering
      if (!isHovering) {
        startAutoPlay();
      }
    }

    card.addEventListener('mouseleave', function() {
      if (isPlaying) {
        pause();
        video.currentTime = 0;
      }
    });

    if (playBtn) {
      playBtn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        if (isPlaying) {
          pause();
          userPaused = true;
        } else {
          play();
        }
      });
    }

    video.addEventListener('click', function(e) {
      e.preventDefault();
      if (isPlaying) {
        pause();
        userPaused = true;
      } else {
        play();
      }
    });

    video.addEventListener('ended', function() {
      pause();
      video.currentTime = 0;
    });
  });

  // Initialize
  updateVisibleCards();
  startAutoPlay();
})();
</script>

{% schema %}
{
  "name": "Pharmacist Recommends",
  "settings": [
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Recommended by pharmacists in Italy"
    }
