<div class="as-seen-on-section">
  <p class="heading">{{ section.settings.heading }}</p>

  <!-- Desktop view: All logos in grid -->
  <div class="logos-desktop">
    <div class="logos-grid">
      {% for block in section.blocks %}
        <div class="logo-item">
          <div class="logo-desktop">
            {% if block.settings.svg_desktop != blank %}
              {{
                block.settings.svg_desktop 
                | image_url: width: 300
                | image_tag: 
                  alt: block.settings.image_alt | default: section.settings.heading,
                  loading: 'lazy'
              }}
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>

  <!-- Mobile view: Hidden navigation carousel -->
  <div class="logos-mobile-carousel">
    <div class="carousel-container">
      <div class="carousel-track">
        {% for block in section.blocks %}
          <div class="carousel-slide">
            <div class="logo-mobile">
              {% if block.settings.svg_mobile != blank %}
                {{
                  block.settings.svg_mobile 
                  | image_url: width: 300
                  | image_tag: 
                    alt: block.settings.image_alt | default: section.settings.heading,
                    loading: 'lazy'
                }}
              {% else %}
                {{
                  block.settings.svg_desktop 
                  | image_url: width: 300
                  | image_tag: 
                    alt: block.settings.image_alt | default: section.settings.heading,
                    loading: 'lazy'
                }}
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<style>
.as-seen-on-section {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 17px;
  background: #F4F5F4;
  padding: 64px 150px;
  position: relative;
}

.as-seen-on-section p {
  margin: 0;
  font-size: 22px;
  font-style: normal;
  font-weight: 500;
  line-height: 21px;
  letter-spacing: -1px;
  color: #17162E;
}

/* Desktop View */
.logos-desktop {
  display: block;
}

.logos-grid {
  display: flex;
  gap: 61px;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
}

.logo-item {
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-desktop img {
  width: auto;
max-width: 232px;
    max-height: 43px;
  display: block;
  object-fit: contain;
}

/* Mobile Carousel - No visible navigation */
.logos-mobile-carousel {
  display: none;
  position: relative;
  width: 100%;
  max-width: 100%;
  overflow: hidden;
}

.carousel-container {
  overflow: hidden;
  width: 100%;
  cursor: grab;
}

.carousel-container:active {
  cursor: grabbing;
}

.carousel-track {
  display: flex;
  transition: transform 0.3s ease-out;
}

.carousel-slide {
  flex: 0 0 33.333%; /* Show 3 logos at a time */
  display: flex;
  {% comment %} justify-content: center; {% endcomment %}
  align-items: center;
  {% comment %} padding: 10px; {% endcomment %}
  box-sizing: border-box;
  pointer-events: none; /* Prevents individual logo clicks during drag */
}

.logo-mobile img {
  width: auto;
  max-width: 113px;
  max-height: 17px;
  display: block;
  object-fit: contain;
  margin: 0 auto;
  pointer-events: auto; /* Re-enable clicks on logos */
}

/* Tablet View */
@media screen and (min-width: 749px) and (max-width: 1300px) {
  .as-seen-on-section {
    padding: 48px 100px;
  }
  
  .as-seen-on-section p {
    font-size: 16px;
    letter-spacing:0px;
    line-height: normal;
  }
  
  .logos-grid {
    gap: 20px;
  }
  
  .logo-desktop img {
    max-width: 120px;
    max-height: 28px;
  }
}

/* Mobile View */
@media screen and (max-width: 749px) {
  .logos-desktop {
    display: none;
  }
  
  .logos-mobile-carousel {
    display: block;
  }
  
  .as-seen-on-section {
    align-items: flex-start;
    padding: 0px 20px 36px;
    width: 100%;
  }
  
  .as-seen-on-section p {
    font-size: 16px;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const section = document.querySelector('.as-seen-on-section');
  if (!section) return;
  
  const carousel = section.querySelector('.logos-mobile-carousel');
  if (!carousel) return;
  
  const container = carousel.querySelector('.carousel-container');
  const track = carousel.querySelector('.carousel-track');
  const slides = carousel.querySelectorAll('.carousel-slide');
  
  if (!container || !track || slides.length === 0) return;
  
  let startX = 0;
  let currentTranslate = 0;
  let prevTranslate = 0;
  let animationID = 0;
  let isDragging = false;
  let currentIndex = 0;
  
  const slidesToShow = 3; // Show 3 logos at a time
  const totalSlides = slides.length;
  const maxIndex = Math.ceil(totalSlides / slidesToShow) - 1;
  
  // Get the width of one slide
  function getSlideWidth() {
    return slides[0].offsetWidth;
  }
  
  // Update carousel position based on current index
  function setPositionByIndex() {
    const slideWidth = getSlideWidth();
    const offset = currentIndex * (slideWidth * slidesToShow);
    currentTranslate = -offset;
    prevTranslate = currentTranslate;
    track.style.transform = `translateX(${currentTranslate}px)`;
  }
  
  // Touch start event
  function touchStart(event) {
    if (totalSlides <= slidesToShow) return;
    
    startX = event.touches[0].clientX;
    isDragging = true;
    container.style.cursor = 'grabbing';
    
    cancelAnimationFrame(animationID);
  }
  
  // Touch move event
  function touchMove(event) {
    if (!isDragging || totalSlides <= slidesToShow) return;
    
    const currentX = event.touches[0].clientX;
    const diff = currentX - startX;
    const slideWidth = getSlideWidth();
    const maxTranslate = 0;
    const minTranslate = -(maxIndex * slideWidth * slidesToShow);
    
    let newTranslate = prevTranslate + diff;
    
    // Add resistance at edges
    if (newTranslate > maxTranslate) {
      newTranslate = maxTranslate + (newTranslate - maxTranslate) * 0.3;
    }
    if (newTranslate < minTranslate) {
      newTranslate = minTranslate + (newTranslate - minTranslate) * 0.3;
    }
    
    currentTranslate = newTranslate;
    track.style.transform = `translateX(${currentTranslate}px)`;
  }
  
  // Touch end event
  function touchEnd(event) {
    if (!isDragging || totalSlides <= slidesToShow) return;
    
    isDragging = false;
    container.style.cursor = 'grab';
    
    const slideWidth = getSlideWidth();
    const movedBy = currentTranslate - prevTranslate;
    const slideWidthWithGap = slideWidth * slidesToShow;
    const threshold = slideWidthWithGap * 0.3;
    
    // Determine if we should change slide
    if (Math.abs(movedBy) > threshold) {
      if (movedBy < 0 && currentIndex < maxIndex) {
        currentIndex++;
      } else if (movedBy > 0 && currentIndex > 0) {
        currentIndex--;
      }
    }
    
    // Smooth transition to final position
    setPositionByIndex();
    
    // Reset animation
    animationID = requestAnimationFrame(() => {
      track.style.transition = 'transform 0.3s ease-out';
      setTimeout(() => {
        track.style.transition = '';
      }, 300);
    });
  }
  
  // Handle window resize
  let resizeTimer;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      if (window.innerWidth <= 749) {
        setPositionByIndex();
      }
    }, 250);
  });
  
  // Initialize carousel on mobile only
  function initCarousel() {
    if (window.innerWidth <= 749 && totalSlides > slidesToShow) {
      setPositionByIndex();
      container.addEventListener('touchstart', touchStart);
      container.addEventListener('touchmove', touchMove);
      container.addEventListener('touchend', touchEnd);
      container.style.cursor = 'grab';
    } else {
      container.removeEventListener('touchstart', touchStart);
      container.removeEventListener('touchmove', touchMove);
      container.removeEventListener('touchend', touchEnd);
      container.style.cursor = 'default';
      currentIndex = 0;
      setPositionByIndex();
    }
  }
  
  // Initial setup
  initCarousel();
  
  // Re-initialize on window resize
  window.addEventListener('resize', initCarousel);
});
</script>

{% schema %}
{
  "name": "As Seen On",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "As seen on"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "svg_desktop",
          "label": "Logo for Desktop"
        },
        {
          "type": "image_picker",
          "id": "svg_mobile",
          "label": "Logo for Mobile"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Alt Text",
          "default": "Logo",
          "info": "Accessibility text for the logo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "As Seen On"
    }
  ]
}
{% endschema %}