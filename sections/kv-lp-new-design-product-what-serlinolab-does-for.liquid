{{ 'kv-lp-new-design-product-what-serlinolab-does-for.css' | asset_url | stylesheet_tag }}

{%- if section.settings.image_desktop != blank -%}
  <picture class="lp-what-serlinolab__bg">
    {%- if section.settings.image_mobile != blank -%}
      <source media="(max-width: 767px)" srcset="{{ section.settings.image_mobile | img_url: 'master' }}">
    {%- endif -%}
    <img
      src="{{ section.settings.image_desktop | img_url: 'master' }}"
      alt="{{ section.settings.heading | escape }}"
      loading="lazy"
      width="{{ section.settings.image_desktop.width }}"
      height="{{ section.settings.image_desktop.height }}"
    >
  </picture>
{%- endif -%}

  <div class="lp-what-serlinolab__overlay"></div>

  <div class="lp-what-serlinolab__container" id="lp-what-serlinolab-container">
    <div class="lp-what-serlinolab__content">
      <h2 class="lp-what-serlinolab__heading">{{ section.settings.heading | newline_to_br }}</h2>
      
      <div class="lp-what-serlinolab__benefits-grid">
        {%- for block in section.blocks -%}
          <div class="lp-benefit-item" {{ block.shopify_attributes }}>
            <div class="lp-benefit-item__icon">
              {%- if block.settings.icon_svg != blank -%}
                {{ block.settings.icon_svg }}
              {%- else -%}
                <div class="lp-benefit-item__icon-placeholder"></div>
              {%- endif -%}
            </div>
            <p class="lp-benefit-item__title">{{ block.settings.title | escape }}</p>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>

  <div class="lp-trustpilot-bar">
    <div class="lp-trustpilot-bar__inner">
      <div class="trustpilot-widget" data-locale="en-US" data-template-id="5419b732fbfb950b10de65e5" data-businessunit-id="6983ad4bc5b7f0ff5cd3dc11" data-style-height="24px" data-style-width="100%" data-theme="dark" data-token="8793ee1f-5401-4ce5-9b04-2cbb5c2aac35">
        <a href="https://www.trustpilot.com/review/www.serlinolab.com" target="_blank" rel="noopener">Trustpilot</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "SerlinoLab Science",
  "settings": [
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "What SerlinoLab does\nfor your skin"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Background Image (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Background Image (Mobile)"
    },
    {
      "type": "text",
      "id": "trustpilot_score",
      "label": "Trustpilot Score",
      "default": "4.6 Excellent"
    },
    {
      "type": "text",
      "id": "trustpilot_reviews",
      "label": "Trustpilot Reviews",
      "default": "3,439+ reviews"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Section Height (Mobile)",
      "info": "Height in pixels for screens up to 780px",
      "min": 300,
      "max": 1000,
      "step": 10,
      "default": 740,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon (SVG Code)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SerlinoLab Science",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "title": "Visible wrinkle reduction*"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Firmer feel in 2 weeks*"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Softer, more elastic skin*"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Rapid absorption"
          }
        }
      ]
    }
  ]
}
{% endschema %}