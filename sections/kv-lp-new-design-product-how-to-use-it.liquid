          <path d="M8.18525 0C8.45091 0 8.67349 0.0879498 8.85299 0.263851C9.03249 0.432717 9.12224 0.647317 9.12224 0.907651C9.12224 1.0343 9.1007 1.15391 9.05762 1.26649C9.01454 1.3861 8.94992 1.48813 8.86376 1.57256L6.45127 3.97889L1.96015 8L6.45127 12.0211L8.86376 14.4274C8.94992 14.5119 9.01454 14.6104 9.05762 14.723C9.1007 14.8426 9.12224 14.9657 9.12224 15.0923C9.12224 15.3527 9.03249 15.5673 8.85299 15.7361C8.67349 15.912 8.45091 16 8.18525 16C8.056 16 7.93394 15.9754 7.81906 15.9261C7.697 15.8769 7.57853 15.796 7.46365 15.6834L0.323101 8.70712C0.1077 8.50308 0 8.26737 0 8C0 7.73263 0.1077 7.49692 0.323101 7.29288L7.48519 0.295514C7.69341 0.0985041 7.92676 0 8.18525 0ZM19.0522 7.06069C19.3323 7.06069 19.562 7.14864 19.7415 7.32454C19.9138 7.50044 20 7.72559 20 8C20 8.27441 19.9138 8.49956 19.7415 8.67546C19.562 8.85136 19.3323 8.93931 19.0522 8.93931L5.42811 8.93931L1.96015 8.72823C1.73757 8.71416 1.55807 8.6438 1.42165 8.51715C1.28523 8.3905 1.21702 8.21812 1.21702 8C1.21702 7.78892 1.28523 7.62005 1.42165 7.4934C1.55807 7.36675 1.73757 7.29288 1.96015 7.27177L5.42811 7.06069L19.0522 7.06069Z" fill="#1A2A49"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const section = document.querySelector('#lp-how-to-use-{{ section.id }}');
  if (!section) return;

const adviceToggle = section.querySelector('[data-advice-toggle]');
const adviceContent = section.querySelector('[data-advice-content]');
const plusIcon = section.querySelector('.lp-how-to-use__icon-plus');
const minusIcon = section.querySelector('.lp-how-to-use__icon-minus');

if (adviceToggle && adviceContent) {
  adviceToggle.addEventListener('click', function() {
    const isOpen = adviceContent.classList.contains('is-open');
    
    if (isOpen) {
      adviceContent.classList.remove('is-open');
      if (plusIcon) plusIcon.style.display = 'block';
      if (minusIcon) minusIcon.style.display = 'none';
      section.classList.remove('is-steps-open');
    } else {
      adviceContent.classList.add('is-open');
      if (plusIcon) plusIcon.style.display = 'none';
      if (minusIcon) minusIcon.style.display = 'block';
      section.classList.add('is-steps-open');
    }
  });
}

  const grid = section.querySelector('[data-carousel]');
  const dots = section.querySelectorAll('[data-dot]');
  const prevBtn = section.querySelector('[data-nav="prev"]');
  const nextBtn = section.querySelector('[data-nav="next"]');
  const cards = section.querySelectorAll('.lp-how-to-use__card');
  const totalCards = cards.length;
  
  if (totalCards === 0) return;

  function getGap() {
    return parseFloat(getComputedStyle(grid).gap) || 20;
  }

  function getCardWidth() {
    return cards[0].offsetWidth;
  }

  function getScrollPositionForCard(index) {
    const gap = getGap();
    const cardWidth = getCardWidth();
    return index * (cardWidth + gap);
  }

  function getCurrentCardIndex() {
    const gap = getGap();
    const cardWidth = getCardWidth();
    const scrollPosition = grid.scrollLeft;
    const index = Math.round(scrollPosition / (cardWidth + gap));
    return Math.min(Math.max(0, index), totalCards - 1);
  }

  function updateButtonStates() {
    const currentIndex = getCurrentCardIndex();

    if (currentIndex === 0) {
      prevBtn.classList.add('is-disabled');
      prevBtn.classList.remove('is-active');
      prevBtn.setAttribute('disabled', '');
      prevBtn.setAttribute('aria-disabled', 'true');
    } else {
      prevBtn.classList.remove('is-disabled');
      prevBtn.classList.add('is-active');
      prevBtn.removeAttribute('disabled');
      prevBtn.setAttribute('aria-disabled', 'false');
    }

    if (currentIndex === totalCards - 1) {
      nextBtn.classList.add('is-disabled');
      nextBtn.classList.remove('is-active');
      nextBtn.setAttribute('disabled', '');
      nextBtn.setAttribute('aria-disabled', 'true');
    } else {
      nextBtn.classList.remove('is-disabled');
      nextBtn.classList.add('is-active');
      nextBtn.removeAttribute('disabled');
      nextBtn.setAttribute('aria-disabled', 'false');
    }
  }

  function updateDots() {
    const currentIndex = getCurrentCardIndex();
    
    dots.forEach((dot, index) => {
      dot.classList.toggle('is-active', index === currentIndex);
    });
  }

  function scrollToCard(index, smooth = true) {
    if (index < 0) index = 0;
    if (index >= totalCards) index = totalCards - 1;
    
    const scrollPosition = getScrollPositionForCard(index);
    
    grid.scrollTo({
      left: scrollPosition,
      behavior: smooth ? 'smooth' : 'auto'
    });
  }

  // Update states on scroll
  let scrollTimeout;
  grid.addEventListener('scroll', function() {
    clearTimeout(scrollTimeout);
    scrollTimeout = setTimeout(() => {
      updateDots();
      updateButtonStates();
    }, 50);
  });

  prevBtn.addEventListener('click', () => {
    if (prevBtn.hasAttribute('disabled')) return;
    const currentIndex = getCurrentCardIndex();
    if (currentIndex > 0) {
      scrollToCard(currentIndex - 1);
    }
  });

  nextBtn.addEventListener('click', () => {
    if (nextBtn.hasAttribute('disabled')) return;
    const currentIndex = getCurrentCardIndex();
    if (currentIndex < totalCards - 1) {
      scrollToCard(currentIndex + 1);
    }
  });

  // Dot click handlers
  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      scrollToCard(index);
    });
  });

  // Touch swipe support
  let touchStartX = 0;
  let touchEndX = 0;
  const wrapper = section.querySelector('.lp-how-to-use__grid-wrapper');
  
  if (wrapper) {
    wrapper.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    });
    
    wrapper.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      const swipeThreshold = 50;
      const currentIndex = getCurrentCardIndex();
      
      if (touchEndX < touchStartX - swipeThreshold && currentIndex < totalCards - 1) {
        scrollToCard(currentIndex + 1);
      } else if (touchEndX > touchStartX + swipeThreshold && currentIndex > 0) {
        scrollToCard(currentIndex - 1);
      }
    });
  }

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    const rect = section.getBoundingClientRect();
    const isVisible = rect.top < window.innerHeight && rect.bottom > 0;
    
    if (!isVisible) return;
    
    const currentIndex = getCurrentCardIndex();
    
    if (e.key === 'ArrowLeft' && currentIndex > 0) {
      scrollToCard(currentIndex - 1);
      e.preventDefault();
    } else if (e.key === 'ArrowRight' && currentIndex < totalCards - 1) {
      scrollToCard(currentIndex + 1);
      e.preventDefault();
    }
  });

  // Initialize
  function initialize() {
    // Ensure we start at the first card
    scrollToCard(0, false);
    updateButtonStates();
    updateDots();
  }

  // Handle window resize
  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      const currentIndex = getCurrentCardIndex();
      scrollToCard(currentIndex, false);
      updateButtonStates();
      updateDots();
    }, 250);
  });

  // Initialize after images load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initialize);
  } else {
    initialize();
  }
});
</script>

