{{ 'kv-lp-new-design-product-italian-formula.css' | asset_url | stylesheet_tag }}

<section class="lp-comparison-table" id="lp-section-{{ section.id }}">
  {% if section.settings.bg_image != blank %}
    <img src="{{ section.settings.bg_image | image_url: width: 2000 }}" class="lp-comparison-table__bg" alt="" loading="lazy">
  {% endif %}
  <div class="lp-comparison-table__overlay" id="lp-comparison-table-overlay" style="background-color: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity }};"></div>

  <div class="lp-comparison-table__container">
    <div class="lp-comparison-table__header">
      <h2 class="lp-comparison-table__heading">{{ section.settings.heading }}</h2>
    </div>

    <div class="lp-comparison-table__wrapper">
      <div class="lp-comparison-table__grid">
        <div class="lp-comparison-table__col lp-comparison-table__col--features">
          {% for block in section.blocks %}
            <div class="lp-comparison-table__cell lp-comparison-table__cell--feature" {{ block.shopify_attributes }}>
              {{ block.settings.feature_name }}
            </div>
          {% endfor %}
        </div>

        <div class="lp-comparison-table__col lp-comparison-table__col--brand">
          <div class="lp-comparison-table__cell lp-comparison-table__cell--header">
           
              <img src="{{ section.settings.brand_logo | image_url: width: 100 }}" alt="Brand Logo" class="lp-comparison-table__logo">
