{{ 'kv-lp-new-design-product-results-others-notice.css' | asset_url | stylesheet_tag }}

<section class="lp-results-notice" id="lp-section-{{ section.id }}">
  <div class="lp-results-notice__container" id="lp-results-notice-container">
    {% if section.settings.title != blank %}
      <header class="lp-results-notice__header">
        <h2 class="lp-results-notice__title">{{ section.settings.title }}</h2>
      </header>
    {% endif %}

    <div class="lp-results-notice__list-wrapper">
      <div class="lp-results-notice__list">
        {% for block in section.blocks %}
          <div class="lp-results-notice__card" {{ block.shopify_attributes }}>
            <div class="lp-results-notice__media">
              <div class="lp-results-notice__images-grid">
                <div class="lp-results-notice__img-box">
                  {% if block.settings.image_before != blank %}
                    {{ block.settings.image_before | image_url: width: 400 | image_tag: loading: 'lazy', class: 'lp-results-notice__img' }}
                  {% else %}
                    {{ 'image' | placeholder_svg_tag: 'lp-results-notice__placeholder' }}
                  {% endif %}
                  <span class="lp-results-notice__label">{{ block.settings.label_before }}</span>
                </div>
                <div class="lp-results-notice__img-box">
                  {% if block.settings.image_after != blank %}
                    {{ block.settings.image_after | image_url: width: 400 | image_tag: loading: 'lazy', class: 'lp-results-notice__img' }}
                  {% else %}
                    {{ 'image' | placeholder_svg_tag: 'lp-results-notice__placeholder' }}
                  {% endif %}
                  <span class="lp-results-notice__label">{{ block.settings.label_after }}</span>
                </div>
              </div>
            </div>

            <div class="lp-results-notice__info">
              <h3 class="lp-results-notice__reviewer-name">{{ block.settings.reviewer_name }}</h3>
              <p class="lp-results-notice__reviewer-subtitle">{{ block.settings.reviewer_subtitle }}</p>
              <p class="lp-results-notice__testimonial">
                {{ block.settings.testimonial }}
              </p>
              <div class="lp-results-notice__tags">
                {% if block.settings.tag_1 != blank %}
                  <span class="lp-results-notice__tag">{{ block.settings.tag_1 }}</span>
                {% endif %}
                {% if block.settings.tag_2 != blank %}
                  <span class="lp-results-notice__tag">{{ block.settings.tag_2 }}</span>
                {% endif %}
                 {% if block.settings.tag_3 != blank %}
                  <span class="lp-results-notice__tag">{{ block.settings.tag_3 }}</span>
                {% endif %}
              </div>
              {% comment %} <p class="lp-results-notice__routine">{{ block.settings.product_info | newline_to_br }}</p> {% endcomment %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
    <div class="lp-results__nav">
      <button class="lp-how-to-use__arrow lp-how-to-use__arrow--prev" data-nav="prev" aria-label="Previous step">
        <svg width="20" height="16" viewBox="0 0 20 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M8 1L1 8L8 15M1 8H19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="lp-how-to-use__dots">
        {% for block in section.blocks %}
          <span class="lp-how-to-use__dot{% if forloop.first %} is-active{% endif %}" data-dot="{{ forloop.index0 }}"></span>
        {% endfor %}
      </div>
      <button class="lp-how-to-use__arrow lp-how-to-use__arrow--next" data-nav="next" aria-label="Next step">
        <svg width="20" height="16" viewBox="0 0 20 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 1L19 8L12 15M19 8H1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
 <script>
(function() {
  const section = document.querySelector('#lp-section-{{ section.id }}');
  if (!section) return;

  const list = section.querySelector('.lp-results-notice__list');
  const prevBtn = section.querySelector('[data-nav="prev"]');
  const nextBtn = section.querySelector('[data-nav="next"]');
  const dots = section.querySelectorAll('.lp-how-to-use__dot');
  const wrapper = section.querySelector('.lp-results-notice__list-wrapper');
  
  if (!list || !prevBtn || !nextBtn || !dots.length) return;

  let currentIndex = 0;
  const totalCards = dots.length;

  // Get the container width for proper scrolling
  function getCardWidth() {
    const cards = list.querySelectorAll('.lp-results-notice__card');
    if (cards.length === 0) return 0;
    return cards[0].offsetWidth;
  }

  // Function to update the carousel position
  function updateCarousel(index) {
    // Update active dot
    dots.forEach((dot, i) => {
      if (i === index) {
        dot.classList.add('is-active');
      } else {
        dot.classList.remove('is-active');
      }
    });
    
    // Scroll the list to show the active card
    const cards = list.querySelectorAll('.lp-results-notice__card');
    if (cards[index]) {
      const cardWidth = getCardWidth();
      const scrollPosition = cards[index].offsetLeft;
      
      list.scrollTo({
        left: scrollPosition,
        behavior: 'smooth'
      });
    }
    
    currentIndex = index;
  }

  // Recalculate on window resize
  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      updateCarousel(currentIndex);
    }, 250);
  });

  // Next button click handler
  nextBtn.addEventListener('click', () => {
    let newIndex = currentIndex + 1;
    if (newIndex >= totalCards) {
      newIndex = 0;
    }
    updateCarousel(newIndex);
  });

  // Previous button click handler
  prevBtn.addEventListener('click', () => {
    let newIndex = currentIndex - 1;
    if (newIndex < 0) {
      newIndex = totalCards - 1;
    }
    updateCarousel(newIndex);
  });

  // Dot click handlers
  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      updateCarousel(index);
    });
  });

  // Handle scroll end to update active dot
  let scrollTimeout;
  list.addEventListener('scroll', () => {
    clearTimeout(scrollTimeout);
    scrollTimeout = setTimeout(() => {
      const scrollPosition = list.scrollLeft;
      const cards = list.querySelectorAll('.lp-results-notice__card');
      
      let closestIndex = 0;
      let closestDistance = Infinity;
      
      cards.forEach((card, idx) => {
        const distance = Math.abs(card.offsetLeft - scrollPosition);
        if (distance < closestDistance) {
          closestDistance = distance;
          closestIndex = idx;
        }
      });
      
      if (closestIndex !== currentIndex) {
        currentIndex = closestIndex;
        dots.forEach((dot, i) => {
          if (i === currentIndex) {
            dot.classList.add('is-active');
          } else {
            dot.classList.remove('is-active');
          }
        });
      }
    }, 100);
  });

  // Touch swipe support
  let touchStartX = 0;
  let touchEndX = 0;
  
  if (wrapper) {
    wrapper.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    });
    
    wrapper.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      const swipeThreshold = 50;
      
      if (touchEndX < touchStartX - swipeThreshold) {
        nextBtn.click();
      } else if (touchEndX > touchStartX + swipeThreshold) {
        prevBtn.click();
      }
    });
  }

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    const rect = section.getBoundingClientRect();
    const isVisible = rect.top < window.innerHeight && rect.bottom > 0;
    
    if (!isVisible) return;
    
    if (e.key === 'ArrowLeft') {
      prevBtn.click();
      e.preventDefault();
    } else if (e.key === 'ArrowRight') {
      nextBtn.click();
      e.preventDefault();
    }
  });
})();
</script>
</section>

