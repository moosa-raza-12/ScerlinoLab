        "ggfHPA-EHIZ_text": "<p>★ ★ ★ ★ ★ Over 72,000+ Happy Customers | Made in Italy 🇮🇹</p>",
        "ggrY1Kjlf7E_text": "<p>★ ★ ★ ★ ★ Over 72,000+ Happy Customers | Made in Italy 🇮🇹&nbsp;</p>",
