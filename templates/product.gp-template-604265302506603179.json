        "gghcxJ5ZKyH_text": "Quick Absorption without Greasiness!",
        "gg9Z8uU6HVE_childItem_0": "<p><strong>The fragrance: </strong>light touch of lavender</p>",
        "gg9Z8uU6HVE_childItem_1": "<p><strong>The consistency: </strong>light and very fresh</p>",
        "gg9Z8uU6HVE_childItem_2": "<p><strong>Makes your skin feel: </strong>hydrated, soft and smooth</p>",
