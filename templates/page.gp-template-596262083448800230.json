        "ggViVcr5Qg7_text": "<span style=\"color:#17162E;\">Look Visibly Younger in Weeks</span>",
        "ggdmG_Sr0Fx_text": "<span style=\"color:#17162E;\"><strong>Visible Results in</strong></span><br><span style=\"color:#17162E;\"><strong>Just 4 Weeks</strong></span>",
        "ggwENw7wyWK_text": "<p>Maximum effectiveness after 2 bottle. Results may vary from person to person</p>"
