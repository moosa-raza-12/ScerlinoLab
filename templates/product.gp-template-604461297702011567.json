    "gp_section_604461297836753583": {
      "settings": {
        "checksum": "4efad950e96d5c8fa8a965e8bb853d40f54063a1c8b4ea383205d4bdc90df22e_1_1_1_0__1",
        "gg0zbjVVCnF_label": "<p>ITALIAN OIL OLIVE</p>",
        "gg1j4ei5grg_label": "<p><strong>SODIUM HYALURONATE</strong></p>",
        "gg2yGs5LDlR_text": "<p><span style=\"background-color:transparent;color:#000000;font-size:11pt;\">aqua, propylene glycol, glycerin, caprylic/capric triglyceride, hydrogenated ethylhexyl olivate, glyceryl stearate se, aloe barbadensis leaf juice, sodium polyacrylate, phenoxyethanol, hydrogenated olive oil unsaponifiables, tocopherol, tetrasodium glutamate diacetate, urea, trehalose, ethylhexylglycerin, hydrolyzed rice protein, lavandula angustifolia oil, propanediol, sorbitol, linalool, lecithin, olive oil peg-8 esters, helianthus annuus seed oil, tocopheryl acetate, hydroxyethylcellulose, sodium hyaluronate, potassium sorbate, sodium benzoate, xanthan gum, benzyl alcohol, sodium ascorbyl phosphate, limonene, retinyl palmitate, daucus carota sativa root, ascorbic acid, citric acid</span></p>",
        "ggLeqJI7XQW_childItem_0": "<p>Full Ingredient List</p>",
        "ggU84KAzI43_text": "<p>A powerful antioxidant sourced from organic groves in Marche, Italy. Protects your skin barrier from environmental damage while deeply nourishing overnight.</p><p> </p><p><strong>BENEFITS:</strong></p><ul>\n<li>Shields skin from daily damage</li>\n<li>Nourishes without clogging pores</li>\n<li>Restores natural moisture balance</li>\n</ul>",
        "ggkvOXZntCM_text": "<p>They don't just hydrate, but actively fight the signs of time</p>",
        "ggq2VeAT1Um_text": "<p>A bio-identical form of Vitamin A your skin recognizes as its own. Gentler than harsh retinol, it stimulates collagen production without redness or peeling.</p><p> </p><p><strong>BENEFITS:</strong></p><ul>\n<li>Stimulates collagen production</li>\n<li>Reduces wrinkles and fine lines</li>\n<li>Firms and tightens skin over time</li>\n</ul>",
        "ggtOVHAQdCx_text": "<p>A low molecular weight form of hyaluronic acid that penetrates deeper than regular HA. Fills wrinkles from within for visible plumping.</p><p> </p><p><strong>BENEFITS:</strong></p><ul>\n<li>Penetrates deeper than standard HA</li>\n<li>Fills wrinkles from the inside</li>\n<li>Plumper, more hydrated skin</li>\n</ul>",
        "ggv1U-w8hnC_label": "<p>RETINYL PALMITATE</p>",
        "ggwTMw9UkAs_text": "<span style=\"color:#17162E;\">Anti-aging ingredients. Dermatologist Approved.</span>"
      },
      "type": "gp-section-604461297836753583"
    },
    "gp_section_604461297836819119": {
      "settings": {
        "checksum": "4a6390e54c9f23b7c8a6e79dcd61a1ef8c12cb3460c4d219e504b5bece8b993b_1_1_1_0__1",
        "gg0JcSIpWVP_text": "<p>All SerlinoLab creams are <strong>Made in Italy,</strong> produced by a<strong> small family owned</strong> <strong>lab with 38 years of experience.</strong></p><p> </p><p>❌ You won’t find: silicones, parabens, alcohol, synthetic fragrances. And of course, we do NOT test on animals!</p>",
        "gg6L9RXZIQ8_text": "<span style=\"color:#17162E;\">Dermatologically Tested in Italy 🇮🇹</span>",
        "ggdM8K5nK79_text": "Dermatologically <br><span style=\"color:#17162E;\">Tested in Italy 🇮🇹</span>"
      },
      "type": "gp-section-604461297836819119"
    },
    "gp_section_604461297836884655": {
      "settings": {
        "checksum": "2a72337f88803ffd4f834925f861ed8d0c0465ca636f3db2b19e5b35cec9c864_1_1_1_0__1",
        "ggKMPNHMnkK_text": "<span style=\"color:#17162E;\">The Science Behind SerlinoLab</span>",
        "ggSw3FaJfsv_text": "<p>Every year after 40 men <strong>lose 1% of collagen</strong>. SerlinoLab helps counteract this process for a more <strong>toned </strong>and <strong>youthful</strong> face.</p>"
      },
      "type": "gp-section-604461297836884655"
    },
