{{ 'kv-lp-new-design-product-night-cream-anti-aging.css' | asset_url | stylesheet_tag }}

<section class="lp-product-details" data-section-id="{{ section.id }}" data-product-url="{{ product.url | within: collection }}">
  <div class="lp-product-details__container">
    {% comment %} Gallery Section {% endcomment %}
    <div class="lp-product-gallery">
      <div class="lp-product-gallery__main">
        {%- assign extra_image_count = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'gallery_image' and block.settings.image != blank -%}
            {%- assign extra_image_count = extra_image_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
        {%- assign total_slides = product.images.size | plus: extra_image_count -%}
        {%- assign slide_index = 0 -%}

        <div class="lp-product-gallery__track" id="GalleryTrack-{{ section.id }}">
          {% if product.images.size > 0 %}
            {% for image in product.images %}
              {%- assign img_alt = image.alt | default: product.title -%}
              <div class="lp-product-gallery__item{% if slide_index == 0 %} active{% endif %}">
                <img
                  src="{{ image | image_url: width: 800 }}"
                  alt="{{ img_alt | escape }}"
                  loading="lazy"
                  width="{{ image.width }}"
                  height="{{ image.height }}"
                  class="lp-product-gallery__img"
                >
              </div>
              {%- assign slide_index = slide_index | plus: 1 -%}
            {% endfor %}
          {% endif %}

          {% for block in section.blocks %}
            {% if block.type == 'gallery_image' and block.settings.image != blank %}
              {%- assign extra_alt = block.settings.image.alt | default: product.title -%}
              <div class="lp-product-gallery__item" {{ block.shopify_attributes }}>
                <img
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  alt="{{ extra_alt | escape }}"
                  loading="lazy"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                  class="lp-product-gallery__img"
                >
              </div>
              {%- assign slide_index = slide_index | plus: 1 -%}
            {% endif %}
          {% endfor %}

          {% if total_slides == 0 %}
            <div class="lp-product-gallery__item active">
              {{ 'product-1' | placeholder_svg_tag: 'lp-product-gallery__img' }}
            </div>
          {% endif %}
        </div>
        
        {% if total_slides > 1 %}
          <div class="lp-product-gallery__nav">
            <button class="lp-product-gallery__arrow lp-product-gallery__arrow--prev" aria-label="Previous">
              <svg width="20" height="16" viewBox="0 0 20 16" fill="none"><path d="M8 1L1 8L8 15M1 8H19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="lp-product-gallery__dots">
              {% for i in (1..total_slides) %}
                <span class="lp-product-gallery__dot{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}"></span>
              {% endfor %}
            </div>
            <button class="lp-product-gallery__arrow lp-product-gallery__arrow--next" aria-label="Next">
              <svg width="20" height="16" viewBox="0 0 20 16" fill="none"><path d="M12 1L19 8L12 15M19 8H1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>
        {% endif %}
      </div>
    </div>

    {% comment %} Info Section {% endcomment %}
    <div class="lp-product-info">
      <div class="lp-product-info__trust">
        <div class="lp-trustpilot-badge">
          {% if section.settings.trustpilot_icon != blank %}
            <img
              src="{{ section.settings.trustpilot_icon | image_url: width: 184 }}"
              alt="Trustpilot"
              loading="lazy"
              width="{{ section.settings.trustpilot_icon.width }}"
              height="{{ section.settings.trustpilot_icon.height }}"
              class="lp-trustpilot-icon-img"
            >
          {% else %}
            <svg width="92" height="18" viewBox="0 0 92 18" fill="none"><path d="M17.2275 6.518L10.6482 6.518L8.61375 0.25L6.5793 6.518L0 6.518L5.3242 10.385L3.28975 16.653L8.61395 12.786L13.9382 16.653L11.9037 10.385L17.2275 6.518Z" fill="#00B67A"/></svg>
          {% endif %}
          {% if section.settings.trustpilot_text != blank %}
            <div class="lp-trust-text-content">{{ section.settings.trustpilot_text }}</div>
          {% else %}
            <span class="lp-trust-text">4.6 Excellent</span>
            <span class="lp-trust-divider">|</span>
            <span class="lp-trust-reviews">3,439+ reviews</span>
          {% endif %}
        </div>
      </div>

      <div class="lp-product-title">{% if section.settings.title_override != blank %}{{ section.settings.title_override }}{% else %}<p>{{ product.title }}</p>{% endif %}</div>
      <div class="lp-product-description">{% if section.settings.description_override != blank %}{{ section.settings.description_override }}{% else %}{{ product.description }}{% endif %}</div>

      <div class="lp-benefits-grid">
        {% for block in section.blocks %}
          {% if block.type == 'benefit' %}
            <div class="lp-benefit-card">
              <div class="lp-benefit-icon">
                {% if block.settings.icon != blank %}
                  <img src="{{ block.settings.icon | image_url: width: 56 }}" alt="{{ block.settings.text | escape }}" width="28" height="28" loading="lazy" class="lp-benefit-icon-img">
                {% endif %}
              </div>
              <p class="lp-benefit-text">{{ block.settings.text }}</p>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% comment %} Quantity / Bundle Selector {% endcomment %}
      <div class="lp-variant-picker">
        <h3 class="lp-variant-picker__title">Select Quantity</h3>
        <div class="lp-variant-picker__options">
          {% for block in section.blocks %}
            {% if block.type == 'bundle' %}
              <div class="lp-bundle-item" {{ block.shopify_attributes }}>
                {%- assign variant_index = block.settings.variant_index | default: 0 -%}
                {%- assign bundle_variant = product.variants[variant_index] -%}
                <input
                  type="radio"
                  name="bundle-selection"
                  id="bundle-{{ block.id }}"
                  class="lp-bundle-radio"
                  data-variant-id="{{ bundle_variant.id }}"
                  {% if forloop.first %}checked{% endif %}
                >
                <label for="bundle-{{ block.id }}" class="lp-bundle-card">
                  {% if block.settings.badge_text != blank %}
                    <span class="lp-bundle-badge lp-bundle-badge--{{ block.settings.badge_type }}">{{ block.settings.badge_text }}</span>
                  {% endif %}
                  <div class="lp-bundle-header">
                    <div class="lp-bundle-title-group">
                      <span class="lp-bundle-selector-ui"></span>
                      <span class="lp-bundle-title">{{ block.settings.title | default: bundle_variant.title }}</span>
                      {% if block.settings.shipping_info != blank %}
                        <span class="lp-bundle-shipping-tag">{{ block.settings.shipping_info }}</span>
                      {% endif %}
                    </div>
                    <div class="lp-bundle-pricing">
                      {% if bundle_variant.compare_at_price > bundle_variant.price %}
                        <span class="lp-bundle-price-old">{{ bundle_variant.compare_at_price | money }}</span>
                      {% endif %}
                      <span class="lp-bundle-price-new">{{ bundle_variant.price | money }}<small>/ea</small></span>
                    </div>
                  </div>
                  
                  {% if block.settings.free_gift_content != blank %}
                    <div class="lp-bundle-gifts">
                      <div class="lp-gifts-header">Free gifts included (worth {{ block.settings.gift_value }}):</div>
                      <div class="lp-gift-items">
                        {{ block.settings.free_gift_content }}
                      </div>
                    </div>
                  {% endif %}
                </label>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <p class="lp-results-note">Visible results in ~4 weeks. Maximum effectiveness commonly reported after 2 bottles. Results may vary person to person</p>

      <div class="lp-atc-section">
        {%- assign selected_variant = product.selected_or_first_available_variant -%}
        <product-form>
          {%- form 'product', product, id: 'ProductForm-lp', novalidate: 'novalidate' -%}
            <input type="hidden" name="id" value="{{ selected_variant.id }}" id="lpVariantId-{{ section.id }}">
            <button type="submit" class="lp-atc-button" {% unless selected_variant.available %}disabled{% endunless %}>
              <span>{% if selected_variant.available %}Add to cart{% else %}Sold out{% endif %}</span>
              <span class="lp-atc-price">
                {% if selected_variant.compare_at_price > selected_variant.price %}
                  <del>{{ selected_variant.compare_at_price | money }}</del>
                {% endif %}
                <strong>{{ selected_variant.price | money }}</strong>
              </span>
            </button>
          {%- endform -%}
        </product-form>
        <div class="lp-shipping-meta">
          <span class="lp-meta-item"><span class="lp-dot"></span> Fast delivery</span>
          <span class="lp-meta-item"><img src="https://cdn.shopify.com/s/files/1/0656/3453/3633/files/truck.png?v=1715587421" alt="" width="16"> FREE Shipping to USA</span>
        </div>
      </div>

      <div class="lp-guarantee-banner">
        {% if section.settings.guarantee_icon != blank %}
          <div class="lp-guarantee-icon">
            {{ section.settings.guarantee_icon | image_url: width: 80 | image_tag: loading: 'lazy', alt: 'Guarantee', class: 'lp-guarantee-icon-img' }}
          </div>
        {% endif %}
        <div class="lp-guarantee-text">{{ section.settings.guarantee_text }}</div>
      </div>

      <div class="lp-faq-section">
        {% for block in section.blocks %}
          {% if block.type == 'faq' %}
            <details class="lp-faq-item">
              <summary class="lp-faq-summary">
                <span>{{ block.settings.question }}</span>
                <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M5 8L11 14L17 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </summary>
              <div class="lp-faq-content">
                {{ block.settings.answer }}
              </div>
            </details>
          {% endif %}
        {% endfor %}
      </div>

      <div class="lp-testimonials">
        <h2 class="lp-testimonials__title">Join 100,000+ others</h2>
        <div class="lp-testimonials__slider" id="TestimonialsSlider-{{ section.id }}">
          {% for block in section.blocks %}
            {% if block.type == 'testimonial_video' %}
              <div class="lp-testimonial-card" {{ block.shopify_attributes }}>
                <div class="lp-video-wrapper" data-video-type="hosted">
                  {% if block.settings.video != blank %}
                    <video
                      class="lp-video-native"
                      src="{{ block.settings.video.sources[1].url | default: block.settings.video.sources[0].url }}"
                      muted
                      loop
                      playsinline
                      preload="metadata"
                    ></video>
                  {% endif %}
                  <button class="lp-video-play" aria-label="Play Video">
                    <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none"><path d="M14.9927 30C12.9221 30 10.9821 29.6079 9.17271 28.8238C7.36333 28.0494 5.77165 26.9748 4.39768 25.6002C3.02371 24.2256 1.94485 22.6331 1.1611 20.8228C0.387034 19.0126 0 17.0716 0 15C0 12.9284 0.387034 10.9874 1.1611 9.17715C1.94485 7.35721 3.02371 5.76476 4.39768 4.39981C5.77165 3.02517 7.36333 1.95063 9.17271 1.17619C10.9821 0.392062 12.9221 0 14.9927 0C17.0634 0 19.0034 0.392062 20.8128 1.17619C22.6318 1.95063 24.2284 3.02517 25.6023 4.39981C26.9763 5.76476 28.0503 7.35721 28.8244 9.17715C29.6081 10.9874 30 12.9284 30 15C30 17.0716 29.6081 19.0126 28.8244 20.8228C28.0503 22.6331 26.9763 24.2256 25.6023 25.6002C24.2284 26.9748 22.6318 28.0494 20.8128 28.8238C19.0034 29.6079 17.0634 30 14.9927 30ZM12.3803 20.9245L20.7547 15.9874C20.9966 15.8325 21.1563 15.6341 21.2337 15.3921C21.3208 15.1404 21.3208 14.8887 21.2337 14.637C21.1563 14.3853 20.9966 14.1917 20.7547 14.0561L12.3803 9.09003C12.119 8.93514 11.8481 8.87222 11.5675 8.90126C11.2966 8.9303 11.0692 9.03195 10.8853 9.2062C10.7015 9.37076 10.6096 9.6031 10.6096 9.90319V20.1113C10.6096 20.4114 10.7015 20.6534 10.8853 20.8374C11.0692 21.0116 11.2917 21.1133 11.553 21.1423C11.8239 21.1617 12.0997 21.0891 12.3803 20.9245Z" fill="white"/></svg>
                  </button>
                </div>
                {% if block.settings.video_caption != blank %}
                  <div class="lp-testimonial-card__caption">
                    <span>{{ block.settings.video_caption }}</span>
                  </div>
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
        {%- assign video_count = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'testimonial_video' -%}
            {%- assign video_count = video_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
        <div class="lp-testimonials__scroll-bar" id="TestimonialsScrollBar-{{ section.id }}" data-video-count="{{ video_count }}">
          <div class="lp-testimonials__scroll-thumb" id="TestimonialsScrollThumb-{{ section.id }}"></div>
        </div>
      </div>

      <div class="lp-quick-links">
        <h4 class="lp-quick-links__title">Learn more about:</h4>
        <div class="lp-quick-links__pills">
          {% for block in section.blocks %}
            {% if block.type == 'quick_link' %}
              <a href="#{{ block.settings.section_id }}" class="lp-pill lp-pill--scroll" {{ block.shopify_attributes }}>
                <svg xmlns="http://www.w3.org/2000/svg" width="9" height="5" viewBox="0 0 9 5" fill="none">
                  <path d="M8.14619 0.146431C8.34144 -0.0488152 8.6583 -0.0488057 8.85356 0.146431C9.04881 0.341683 9.04881 0.658528 8.85356 0.853781L4.85367 4.85357C4.65842 5.04881 4.34156 5.04881 4.14631 4.85357L0.146426 0.853781C-0.0487989 0.658528 -0.0488182 0.341674 0.146426 0.146431C0.341673 -0.0487939 0.658537 -0.0487848 0.853791 0.146431L4.49999 3.79255L8.14619 0.146431Z" fill="#434356"/>
                </svg>
                {{ block.settings.label }}
              </a>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const section = document.querySelector('[data-section-id="{{ section.id }}"]');
  if (!section) return;

  /* --- Image gallery carousel --- */
  const track = section.querySelector('#GalleryTrack-{{ section.id }}');
  const items = track ? Array.from(track.querySelectorAll('.lp-product-gallery__item')) : [];
  const dots = section.querySelectorAll('.lp-product-gallery__dot');
  const prevBtn = section.querySelector('.lp-product-gallery__arrow--prev');
  const nextBtn = section.querySelector('.lp-product-gallery__arrow--next');
  let currentSlide = 0;

  function goToSlide(index) {
    if (items.length === 0) return;
    currentSlide = (index + items.length) % items.length;
    track.style.transform = 'translateX(-' + (currentSlide * 100) + '%)';
    dots.forEach(function(dot, i) {
      dot.classList.toggle('active', i === currentSlide);
    });
  }

  if (prevBtn) prevBtn.addEventListener('click', function() { goToSlide(currentSlide - 1); });
  if (nextBtn) nextBtn.addEventListener('click', function() { goToSlide(currentSlide + 1); });
  dots.forEach(function(dot, i) {
    dot.addEventListener('click', function() { goToSlide(i); });
  });

  /* --- Bundle selection → update variant id & ATC price --- */
  const bundleRadios = section.querySelectorAll('.lp-bundle-radio');
  const variantInput = section.querySelector('[id^="lpVariantId"]');
  const atcPrice = section.querySelector('.lp-atc-price');
  const atcButton = section.querySelector('.lp-atc-button');

  bundleRadios.forEach(function(radio) {
    radio.addEventListener('change', function() {
      const variantId = this.dataset.variantId;
      if (variantId && variantInput) {
        variantInput.value = variantId;
      }
      const label = this.nextElementSibling;
      if (label && atcPrice) {
        const oldP = label.querySelector('.lp-bundle-price-old');
        const newP = label.querySelector('.lp-bundle-price-new');
        if (newP) {
          let priceHtml = '';
          if (oldP) priceHtml += '<del>' + oldP.textContent + '</del> ';
          priceHtml += '<strong>' + newP.childNodes[0].textContent.trim() + '</strong>';
          atcPrice.innerHTML = priceHtml;
        }
      }
      if (atcButton) {
        atcButton.disabled = false;
        atcButton.querySelector('span:first-child').textContent = 'Add to cart';
      }
    });
  });

  /* --- Testimonial Video: Autoplay on Hover --- */
  section.querySelectorAll('.lp-testimonial-card').forEach(function(card) {
    var video = card.querySelector('.lp-video-native');
    var playBtn = card.querySelector('.lp-video-play');
    if (!video) return;

    var isPlaying = false;

    function playVideo() {
      video.currentTime = 0;
      video.play().catch(function(){});
      isPlaying = true;
      card.classList.add('is-playing');
    }

    function pauseVideo() {
      video.pause();
      isPlaying = false;
      card.classList.remove('is-playing');
    }

    /* Desktop: hover to play */
    card.addEventListener('mouseenter', playVideo);
    card.addEventListener('mouseleave', pauseVideo);

    /* Mobile: tap play button to toggle */
    if (playBtn) {
      playBtn.addEventListener('click', function(e) {
        e.preventDefault();
        if (isPlaying) {
          pauseVideo();
        } else {
          playVideo();
        }
      });
    }
  });

  /* --- Quick Link Pills: smooth scroll to target section --- */
  section.querySelectorAll('.lp-pill--scroll').forEach(function(pill) {
    pill.addEventListener('click', function(e) {
      var targetId = this.getAttribute('href');
      if (!targetId || targetId === '#') return;
      var targetEl = document.querySelector(targetId);
      if (targetEl) {
        e.preventDefault();
        targetEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  /* --- Testimonials scroll bar (progress bar synced with scroll) --- */
  var slider = section.querySelector('.lp-testimonials__slider');
  var scrollBar = section.querySelector('.lp-testimonials__scroll-bar');
  var thumb = section.querySelector('.lp-testimonials__scroll-thumb');
  var videoCount = parseInt(scrollBar ? scrollBar.dataset.videoCount : 0, 10) || 0;

  if (slider && scrollBar && thumb && videoCount > 0) {
    /* Set the track width dynamically: 120px per video */
    var trackWidth = videoCount * 120;
    scrollBar.style.width = trackWidth + 'px';

    function getMaxScroll() {
      return slider.scrollWidth - slider.clientWidth;
    }

    function getThumbWidth() {
      var barWidth = scrollBar.offsetWidth;
      var max = getMaxScroll();
      if (max <= 0) return barWidth;
      /* Thumb width = proportion of visible area to total scrollable width */
      var ratio = slider.clientWidth / slider.scrollWidth;
      var tw = Math.max(ratio * barWidth, 30); /* min 30px so it stays grabbable */
      return tw;
    }

    function updateThumbPosition() {
      var max = getMaxScroll();
      var barWidth = scrollBar.offsetWidth;
      if (max <= 0) {
        /* No overflow — thumb fills full track */
        thumb.style.left = '0px';
        thumb.style.width = barWidth + 'px';
        return;
      }
      var thumbW = getThumbWidth();
      thumb.style.width = thumbW + 'px';
      var pct = slider.scrollLeft / max;
      var maxLeft = barWidth - thumbW;
      thumb.style.left = (pct * maxLeft) + 'px';
    }

    slider.addEventListener('scroll', updateThumbPosition);
    window.addEventListener('resize', function() {
      trackWidth = videoCount * 120;
      scrollBar.style.width = trackWidth + 'px';
      updateThumbPosition();
    });
    updateThumbPosition();

    /* Make thumb draggable */
    var isDragging = false;
    var dragStartX = 0;
    var dragStartLeft = 0;

    function onThumbDragStart(e) {
      isDragging = true;
      scrollBar.classList.add('is-dragging');
      var clientX = e.touches ? e.touches[0].clientX : e.clientX;
      dragStartX = clientX;
      dragStartLeft = parseFloat(thumb.style.left) || 0;
      e.preventDefault();
    }

    function handleThumbDrag(e) {
      if (!isDragging) return;
      var clientX = e.touches ? e.touches[0].clientX : e.clientX;
      var delta = clientX - dragStartX;
      var barWidth = scrollBar.offsetWidth;
      var thumbW = getThumbWidth();
      var maxLeft = barWidth - thumbW;
      var newLeft = Math.min(Math.max(dragStartLeft + delta, 0), maxLeft);
      var pct = maxLeft > 0 ? newLeft / maxLeft : 0;
      slider.scrollLeft = pct * getMaxScroll();
    }

    function onThumbDragEnd() {
      if (!isDragging) return;
      isDragging = false;
      scrollBar.classList.remove('is-dragging');
    }

    thumb.addEventListener('mousedown', onThumbDragStart);
    thumb.addEventListener('touchstart', onThumbDragStart, { passive: false });
    document.addEventListener('mousemove', handleThumbDrag);
    document.addEventListener('touchmove', handleThumbDrag, { passive: false });
    document.addEventListener('mouseup', onThumbDragEnd);
    document.addEventListener('touchend', onThumbDragEnd);

    /* Click on scroll bar track to jump */
    scrollBar.addEventListener('click', function(e) {
      if (e.target === thumb) return;
      var rect = scrollBar.getBoundingClientRect();
      var clickX = e.clientX - rect.left;
      var barWidth = scrollBar.offsetWidth;
      var thumbW = getThumbWidth();
      var maxLeft = barWidth - thumbW;
      var newLeft = Math.min(Math.max(clickX - thumbW / 2, 0), maxLeft);
      var pct = maxLeft > 0 ? newLeft / maxLeft : 0;
      slider.scrollLeft = pct * getMaxScroll();
    });
  }
});
</script>

{% schema %}
{
  "name": "Product Details Serlino",
  "settings": [
    {
      "type": "image_picker",
      "id": "trustpilot_icon",
      "label": "Trustpilot Badge Icon",
      "info": "Upload a custom icon for the Trustpilot badge area"
    },
    {
      "type": "richtext",
      "id": "trustpilot_text",
      "label": "Trustpilot Badge Text",
      "default": "<p>4.6 Excellent | 3,439+ reviews</p>",
      "info": "Rich text for the Trustpilot badge area. Supports bold, italic, etc."
    },
    {
      "type": "richtext",
      "id": "title_override",
      "label": "Title Override",
      "info": "Leave blank to use the product title. Supports bold, italic, etc."
    },
    {
      "type": "richtext",
      "id": "description_override",
      "label": "Description Override",
      "info": "Leave blank to use the product description"
    },
    {
      "type": "image_picker",
      "id": "guarantee_icon",
      "label": "Guarantee Icon Image",
      "info": "Upload a PNG or SVG image for the guarantee badge icon"
    },
    {
      "type": "richtext",
      "id": "guarantee_text",
      "label": "Guarantee Banner Text",
      "default": "<p>Less than 1% of customers claim our 60 Days Money Back Guarantee.</p>"
    }
  ],
  "blocks": [
    {
      "type": "gallery_image",
      "name": "Gallery Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    },
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    },
    {
      "type": "bundle",
      "name": "Bundle Option",
      "settings": [
        {
